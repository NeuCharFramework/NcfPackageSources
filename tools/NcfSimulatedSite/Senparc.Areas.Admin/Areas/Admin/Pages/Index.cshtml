@page

@model Senparc.Areas.Admin.Pages.IndexModel
@{
    ViewData["Title"] = AR["Dashboard.Title"];
    Layout = "_Layout_Vue";
}
@section style {
    <link rel="stylesheet" href="~/css/Admin/Pages/AdminChat/ChatLauncher.css" />
    <style>
        #home-header .el-main {
            padding: 20px 10px 0px 10px;
            height: auto;
        }

        .xncf-stat-item {
            position: relative;
            display: block;
            margin-bottom: 10px;
            border: 1px solid #E4E4E4;
            overflow: hidden;
            padding-bottom: 5px;
            border-radius: 5px;
            background-clip: padding-box;
            background: #FFF;
            transition: all 300ms ease-in-out;
            padding-left: 10px;
            height: 120px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

            .xncf-stat-item .icon {
                font-size: 45px;
                color: #BAB8B8;
                position: absolute;
                right: 20px;
                top: 50%;
                transform: translateY(-50%);
            }

            .xncf-stat-item .count {
                font-size: 32px;
                font-weight: bold;
                line-height: 1.65857;
            }

            .xncf-stat-item .tit {
                color: #BAB8B8;
                font-size: 18px;
            }

            .xncf-stat-item p {
                margin-bottom: 5px;
            }

        .chart-title {
            font-size: 20px;
        }

        .chart-li {
            padding-top: 20px;
        }

            .chart-li li {
                line-height: 2;
            }

            .chart-li .fa {
                margin-right: 5px;
            }

        .box-card {
            margin-top: 20px
        }

            .box-card:hover {
                border-color: purple; /* border color */
                box-shadow: 0 0 10px rgba(128, 0, 128, 0.5); /* glow shadow color */
            }

        /* Right-side chart area card style override */
        .el-main .el-col-16 .box-card {
            margin-top: 0;
        }

        #xncf-modules-area {
            margin-bottom: 50px;
        }

            #xncf-modules-area .xncf-item {
            }

                #xncf-modules-area .xncf-item .version {
                    float: right;
                }

                #xncf-modules-area .xncf-item .icon {
                    float: left;
                }

                /* Module card style optimization */
                #xncf-modules-area .xncf-item .box-card {
                    height: 160px;
                    transition: all 0.3s ease;
                    cursor: pointer;
                }

                    #xncf-modules-area .xncf-item .box-card:hover {
                        transform: translateY(-5px);
                        border-color: #8c52ff;
                        box-shadow: 0 5px 15px rgba(140, 82, 255, 0.2);
                    }

        /* Module icon style optimization */
        .component-item {
            display: flex;
            align-items: center;
            padding: 15px;
            height: 100%;
        }

            .component-item .icon {
                font-size: 40px;
                color: #8c52ff;
                transition: all 0.3s ease;
                margin-right: 15px;
                flex-shrink: 0;
            }

            .component-item .description {
                flex: 1;
                font-size: 13px;
                color: #666;
                overflow: hidden;
                text-overflow: ellipsis;
                display: -webkit-box;
                -webkit-line-clamp: 3;
                -webkit-box-orient: vertical;
                line-height: 1.5;
            }



        #xncf-modules-area .xncf-item .box-card:hover .icon {
            transform: scale(1.1);
        }



        /* Version number style optimization */
        #xncf-modules-area .xncf-item .version {
            background: #f0f2f5;
            padding: 2px 6px;
            border-radius: 10px;
            font-size: 12px;
            color: #666;
            display: flex;
            align-items: center;
            transition: all 0.3s ease;
        }

            /* Upgradeable version style */
            #xncf-modules-area .xncf-item .version.version-upgradeable {
                background: #e6f1fc;
                color: #409EFF;
                border: 1px solid #b3d8ff;
            }

        .version-upgrade-icon {
            color: #409EFF;
            margin-left: 4px;
            font-size: 14px;
        }

        /* Module name style */
        .xncf-item .el-card__header {
            padding: 10px 15px;
        }

        /* Responsive layout optimization */
        @@media screen and (max-width: 1200px) {
            #xncf-modules-area .el-col-6 {
                width: 33.33%;
            }
        }

        @@media screen and (max-width: 768px) {
            #xncf-modules-area .el-col-6 {
                width: 50%;
            }
        }

        @@media screen and (max-width: 480px) {
            #xncf-modules-area .el-col-6 {
                width: 100%;
            }
        }

        /* Chart container style */
        .charts-container {
            height: 260px;
        }

        /* Remove padding for card content area containing charts-container */
        .el-card__body .charts-container {
            margin-bottom: -40px; /* Offset parent padding, enough whitespace at bottom */
        }

        /* Shake animation keyframes */
        @@keyframes shake {
            0%, 100% {
                transform: translateX(0) rotate(0deg);
            }

            15% {
                transform: translateX(-8px) rotate(-2deg);
            }

            30% {
                transform: translateX(6px) rotate(1.5deg);
            }

            45% {
                transform: translateX(-4px) rotate(-0.5deg);
            }

            60% {
                transform: translateX(2px) rotate(0.25deg);
            }

            75% {
                transform: translateX(-1px) rotate(-0.125deg);
            }
        }

        /* Glow animation keyframes */
        @@keyframes glow {
            0%, 100% {
                box-shadow: 0 0 5px rgba(140, 82, 255, 0.2);
                transform: scale(1);
            }

            50% {
                box-shadow: 0 0 20px rgba(140, 82, 255, 0.6);
                transform: scale(1.02);
            }
        }

        /* Fade effect animation */
        @@keyframes fade {
            0%, 100% {
                opacity: 1;
            }

            50% {
                opacity: 0.6;
            }
        }

        /* Animation classes */
        .shake-animation {
            animation: shake 0.8s cubic-bezier(.36,.07,.19,.97) both;
        }

        .glow-animation {
            animation: glow 1.2s ease-in-out;
        }

        .fade-animation {
            animation: fade 1.2s ease-in-out;
        }

        /* AI chat entrance style */
        #ai-chat-entrance .chat-entrance-card {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border: none;
            border-radius: 15px;
            overflow: hidden;
        }

        .chat-entrance-container {
            color: #fff;
        }

        .chat-entrance-header {
            display: flex;
            align-items: center;
            margin-bottom: 20px;
        }

        .chat-entrance-icon {
            font-size: 50px;
            margin-right: 20px;
            opacity: 0.9;
        }

        .chat-entrance-content {
            flex: 1;
        }

        .chat-entrance-title {
            margin: 0 0 8px 0;
            font-size: 24px;
            font-weight: 600;
            color: #fff;
        }

            .chat-entrance-title .fa {
                margin-right: 8px;
            }

        .chat-entrance-subtitle {
            margin: 0;
            font-size: 14px;
            opacity: 0.9;
        }

        .chat-entrance-input-wrapper {
            margin-bottom: 15px;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .chat-entrance-input .el-textarea__inner {
            background: rgba(255, 255, 255, 0.95);
            border: none;
            border-radius: 15px;
            padding: 15px 20px;
            font-size: 15px;
            line-height: 1.6;
            resize: none;
        }

            .chat-entrance-input .el-textarea__inner:focus {
                background: rgba(255, 255, 255, 1);
                box-shadow: 0 0 0 2px rgba(255, 255, 255, 0.3);
            }

            .chat-entrance-input .el-textarea__inner::placeholder {
                color: #999;
                line-height: 1.6;
            }

        .chat-send-button {
            align-self: flex-end;
            border-radius: 25px;
            padding: 12px 30px;
            font-weight: 600;
            background: linear-gradient(135deg, #5e72e4 0%, #825ee4 100%);
            border: none;
            color: #fff;
            transition: all 0.3s ease;
        }

            .chat-send-button:hover {
                transform: translateY(-2px);
                box-shadow: 0 4px 12px rgba(94, 114, 228, 0.4);
            }

            .chat-send-button:active {
                transform: translateY(0);
            }

        .chat-entrance-tips {
            display: flex;
            justify-content: space-around;
            flex-wrap: wrap;
            gap: 15px;
            margin-bottom: 20px;
        }

        .tip-item {
            font-size: 13px;
            opacity: 0.85;
        }

            .tip-item .fa {
                margin-right: 5px;
            }

        .chat-module-drop-zone {
            background: rgba(255, 255, 255, 0.1);
            border: 2px dashed rgba(255, 255, 255, 0.3);
            border-radius: 10px;
            min-height: 100px;
            padding: 15px;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
            margin-top: 15px;
        }

            .chat-module-drop-zone.drag-over {
                background: rgba(255, 255, 255, 0.2);
                border-color: rgba(255, 255, 255, 0.8);
                border-style: solid;
                border-width: 3px;
            }

        .drop-zone-placeholder {
            text-align: center;
            opacity: 0.7;
            color: #fff;
        }

            .drop-zone-placeholder .fa {
                font-size: 28px;
                margin-bottom: 8px;
                display: block;
            }

            .drop-zone-placeholder p {
                margin: 0;
                font-size: 14px;
            }

        .selected-modules-list {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            width: 100%;
        }

        .module-tag {
            font-size: 14px;
            padding: 8px 12px;
            background: rgba(255, 255, 255, 0.95);
            color: #333;
        }

            .module-tag .fa {
                margin-right: 5px;
            }

        #xncf-modules-area .xncf-item.dragging {
            opacity: 0.5;
        }

        .chat-module-drop-zone.highlight {
            background: rgba(255, 255, 255, 0.25);
            border-color: rgba(255, 255, 255, 0.9);
            border-style: solid;
            border-width: 3px;
            box-shadow: 0 0 20px rgba(255, 255, 255, 0.4);
            transform: scale(1.02);
        }
        
        /* Cursor style during drag */
        #xncf-modules-area .xncf-item[draggable="true"] {
            cursor: grab;
        }
        
        #xncf-modules-area .xncf-item[draggable="true"]:active {
            cursor: grabbing;
        }
    </style>
}

@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Xsrf

<!-- Statistics -->
<div id="home-header">
    <el-container>
        <el-header class="module-header">
            <span class="start-title"><span class="module-header-v">@AR["Dashboard.Header"]</span></span>
        </el-header>
        <el-main>
            <el-row :gutter="20">
                <!-- Left side statistics 2x2 layout -->
                <el-col :span="8">
                    <el-row :gutter="10">
                        <!-- First row -->
                        <el-col :span="12">
                            <a href="~/Admin/XncfModule/Index">
                                <div class="grid-content xncf-stat-item">
                                    <span class="count">{{xncfStat.installedXncfCount || 0}}</span>
                                    <div class="icon">
                                        <i class="fa fa-caret-square-o-right"></i>
                                    </div>
                                    <p class="tit">@AR["Dashboard.InstalledModules"]</p>
                                </div>
                            </a>
                        </el-col>
                        <el-col :span="12">
                            <a href="~/Admin/XncfModule/Index">
                                <div class="grid-content xncf-stat-item">
                                    <span class="count">{{xncfStat.updateVersionXncfCount || 0}}</span>
                                    <div class="icon">
                                        <i class="fa fa-comments-o"></i>
                                    </div>
                                    <p class="tit">@AR["Dashboard.PendingUpdateModules"]</p>
                                </div>
                            </a>
                        </el-col>
                        <!-- Second row -->
                        <el-col :span="12">
                            <a href="~/Admin/XncfModule/Index">
                                <div class="grid-content xncf-stat-item">
                                    <span class="count">{{xncfStat.newXncfCount || 0}}</span>
                                    <div class="icon">
                                        <i class="fa fa-sort-amount-desc"></i>
                                    </div>
                                    <p class="tit">@AR["Dashboard.NewModulesFound"]</p>
                                </div>
                            </a>
                        </el-col>
                        <el-col :span="12">
                            <a href="~/Admin/XncfModule/Index">
                                <div class="grid-content xncf-stat-item">
                                    <span class="count">{{xncfStat.missingXncfCount || 0}}</span>
                                    <div class="icon">
                                        <i class="fa fa-check-square-o"></i>
                                    </div>
                                    <p class="tit">@AR["Dashboard.ModuleErrors"]</p>
                                </div>
                            </a>
                        </el-col>
                    </el-row>
                </el-col>

                <!-- Right side chart area -->
                <el-col :span="16">
                    <el-row :gutter="20">
                        <el-col :span="12">
                            <el-card class="box-card">
                                <div id="firstChart" class="charts-container"></div>
                            </el-card>
                        </el-col>
                        <el-col :span="12">
                            <el-card class="box-card">
                                <div id="secondChart" class="charts-container"></div>
                            </el-card>
                        </el-col>
                    </el-row>
                </el-col>
            </el-row>
        </el-main>
    </el-container>
</div>

<!-- AI Chat Entrance -->
<div id="ai-chat-entrance" style="margin-top: 30px; margin-bottom: 30px;">
    <el-card class="box-card chat-entrance-card">
        <div class="chat-entrance-container">
            <div class="chat-entrance-header">
                <div class="chat-entrance-icon">
                    <i class="fa fa-comments"></i>
                </div>
                <div class="chat-entrance-content">
                    <h3 class="chat-entrance-title">
                        <i class="fa fa-magic"></i> @AR["Dashboard.AIAssistant"]
                    </h3>
                    <p class="chat-entrance-subtitle">@AR["Dashboard.AIAssistant.Subtitle"]</p>
                </div>
            </div>
            
            <div class="chat-entrance-input-wrapper">
                <el-input
                    type="textarea"
                    v-model="chatInputText"
                    placeholder="@AR["Dashboard.AIAssistant.InputPlaceholder"]"
                    :rows="4"
                    :autosize="{ minRows: 4, maxRows: 8 }"
                    @@keydown.native="handleLauncherInputKeydown"
                    class="chat-entrance-input"
                    resize="none">
                </el-input>
                <el-button 
                    type="primary"
                    size="medium"
                    icon="el-icon-s-promotion" 
                    @@click="startChatSession"
                    :disabled="!chatInputText || chatInputText.trim().length === 0"
                    :loading="isCreatingSession"
                    class="chat-send-button">
                    @AR["Dashboard.AIAssistant.StartChat"]
                </el-button>
            </div>

            <div class="chat-entrance-tips">
                <span class="tip-item"><i class="fa fa-lightbulb-o"></i> @AR["Dashboard.AIAssistant.MultiRound"]</span>
                <span class="tip-item"><i class="fa fa-cube"></i> @AR["Dashboard.AIAssistant.AddModuleContext"]</span>
                <span class="tip-item"><i class="fa fa-history"></i> @AR["Dashboard.AIAssistant.AutoSaveHistory"]</span>
            </div>

            <div class="chat-module-picker">
                <div class="chat-module-picker-header">
                    <span class="chat-module-picker-title">@AR["Dashboard.AIAssistant.ReferenceModules"]</span>
                    <div class="chat-module-picker-actions">
                        <el-button size="mini" type="primary" icon="el-icon-plus" @@click="openModuleSelector">@AR["Dashboard.AIAssistant.AddReferenceModule"]</el-button>
                        <el-button size="mini" @@click="clearSelectedModules" v-if="selectedModules.length > 0">@AR["Dashboard.AIAssistant.Clear"]</el-button>
                    </div>
                </div>

                <div v-if="selectedModules.length > 0" class="chat-module-selected-list">
                    <el-tag
                        v-for="module in selectedModules"
                        :key="module.uid"
                        closable
                        @@close="removeModule(module.uid)"
                        type="info"
                        class="module-tag">
                        <i :class="module.icon"></i> {{module.name}}
                    </el-tag>
                </div>
                <div v-else class="chat-module-selected-empty">@AR["Dashboard.AIAssistant.EmptyModuleTip"]</div>
            </div>

            @await Html.PartialAsync("~/Areas/Admin/Pages/Shared/_ChatModuleSelectorDialog.cshtml")
        </div>
    </el-card>
</div>

<!-- Function Modules -->
<div>
    <el-row>
        <el-card class="box-card">
            <div slot="header" class="clearfix">
                <span><i class="fa fa-cubes"></i> @AR["Dashboard.FunctionModules"]</span>
            </div>
            <div id="xncf-modules-area">
                <el-row :gutter="20">
                    <el-col :span="6" class="xncf-item" v-for="item in xncfOpeningList" :key="item.uid">

                        <el-card class="box-card">
                            <div slot="header" class="clearfix">
                                <span>{{item.menuName}}</span>
                                <span class="version version-container" :class="{ 'version-upgradeable': item.hasNewVersion }">
                                    v{{item.version}}
                                    <el-tooltip v-if="item.hasNewVersion"
                                                class="version-tooltip"
                                                effect="light"
                                                :content="`v${item.version} -> v${item.newVersion}`">
                                        <i class="fa fa-level-up version-upgrade-icon"></i>
                                    </el-tooltip>
                                </span>
                                <span v-if="item.menus.length > 0">
                                    <el-popover placement="right"
                                                width="270"
                                                trigger="click">
                                        <el-table v-if="refreshTable"
                                                  v-loading="loading"
                                                  :data="item.menus"
                                                  row-key="id"
                                                  :default-expand-all="isExpandAll"
                                                  :tree-props="{children: 'children', hasChildren: 'hasChildren'}"
                                                  max-height="250"
                                                  :show-header="false">
                                            <el-table-column prop="name" label="@AR["Dashboard.MenuName"]" width="260">
                                                <template slot-scope="scope">
                                                    <a :href="scope.row.url">{{scope.row.name}}</a>
                                                </template>
                                            </el-table-column>
                                        </el-table>
                                        <el-button slot="reference" size="mini" icon="el-icon-s-fold"></el-button>
                                    </el-popover>
                                </span>
                            </div>
                            <a v-bind:href="'/Admin/XncfModule/Start/?uid='+item.uid">
                                <div class="component-item">
                                    <i :class="[item.icon, 'icon']"></i>
                                    <div class="description">{{item.description || '@AR["Dashboard.NoDescription"]'}}</div>
                                </div>
                            </a>
                        </el-card>

                    </el-col>
                </el-row>
            </div>
        </el-card>
    </el-row>
</div>

@section scripts {
    <script src="~/lib/echarts/dist/echarts.js"></script>
    <script>
        Object.assign(window.ncfI18n, {
            logStatistics: @Json.Serialize(AR["Js.logStatistics"].Value),
            last14Days: @Json.Serialize(AR["Js.last14Days"].Value),
            normalLogs: @Json.Serialize(AR["Js.normalLogs"].Value),
            exceptionLogs: @Json.Serialize(AR["Js.exceptionLogs"].Value),
            todayLogStatistics: @Json.Serialize(AR["Js.todayLogStatistics"].Value),
            dynamicData: @Json.Serialize(AR["Js.dynamicData"].Value),
            logType: @Json.Serialize(AR["Js.logType"].Value),
            entries: @Json.Serialize(AR["Js.entries"].Value)
        });
    </script>
    <script src="~/js/Admin/Pages/AdminChat/ChatLauncherMixin.js"></script>
    <script src="~/js/Admin/Pages/Index/Index.js"></script>
}