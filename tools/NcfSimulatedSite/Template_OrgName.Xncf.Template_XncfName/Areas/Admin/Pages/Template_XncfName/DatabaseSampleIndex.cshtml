@page
@model Template_OrgName.Xncf.Template_XncfName.Areas.Template_XncfName.Pages.DatabaseSampleIndex
@{
    ViewData["Title"] = "Color Database Management";
    Layout = "_Layout_Vue";
}

@section Style {
    <link href="~/css/Admin/Template_XncfName/databaseSampleIndex.css" rel="stylesheet" />
}

@section breadcrumbs {
    <el-breadcrumb-item>Extension Modules</el-breadcrumb-item>
    <el-breadcrumb-item>Template_MenuName</el-breadcrumb-item>
    <el-breadcrumb-item>Color Database Management</el-breadcrumb-item>
}

<div>
    <div class="filter-container">
        <el-button type="primary" icon="el-icon-plus" size="small" @@click="addColor">Add Color</el-button>
        <el-button type="success" icon="el-icon-refresh" size="small" @@click="refreshList">Refresh</el-button>
        <el-button type="info" icon="el-icon-info" size="small" @@click="debugInfo">Debug Info</el-button>
    </div>

    <!-- Debug Info Display -->
    <div v-if="showDebug" style="background: #f0f9ff; border: 1px solid #0ea5e9; padding: 10px; margin: 10px 0; border-radius: 4px;">
        <h4>Debug Info:</h4>
        <p><strong>tableData length:</strong> {{ tableData ? tableData.length : 'null/undefined' }}</p>
        <p><strong>total:</strong> {{ total }}</p>
        <p><strong>tableLoading:</strong> {{ tableLoading }}</p>
        <p><strong>Vue instance OK:</strong> {{ $el ? 'Yes' : 'No' }}</p>
        <div v-if="tableData && tableData.length > 0">
            <strong>First record:</strong>
            <pre>{{ JSON.stringify(tableData[0], null, 2) }}</pre>
        </div>
        
        <!-- Simplified data display test -->
        <div style="background: #fff3cd; border: 1px solid #ffc107; padding: 10px; margin: 10px 0; border-radius: 4px;">
            <h5>Simplified data display test:</h5>
            <div v-for="(item, index) in tableData" :key="item.id || index" style="border: 1px solid #ccc; margin: 5px 0; padding: 5px;">
                <strong>ID:</strong> {{item.id}} | 
                <strong>RGB:</strong> {{item.red}},{{item.green}},{{item.blue}} | 
                <strong>Time:</strong> {{item.addTime}}
            </div>
            <p v-if="!tableData || tableData.length === 0" style="color: red;">
                <strong>No data to display!</strong>
            </p>
        </div>
    </div>

    <el-table :data="tableData" v-loading="tableLoading" border>
        <el-table-column prop="id" label="ID" width="auto"></el-table-column>
        <el-table-column prop="red" label="Red (R)" width="auto">
            <template slot-scope="scope">
                <el-tag :style="{backgroundColor: `rgb(${scope.row.red}, 0, 0)`, color: 'white'}">
                    {{scope.row.red}}
                </el-tag>
            </template>
        </el-table-column>
        <el-table-column prop="green" label="Green (G)" width="auto">
            <template slot-scope="scope">
                <el-tag :style="{backgroundColor: `rgb(0, ${scope.row.green}, 0)`, color: 'white'}">
                    {{scope.row.green}}
                </el-tag>
            </template>
        </el-table-column>
        <el-table-column prop="blue" label="Blue (B)" width="auto">
            <template slot-scope="scope">
                <el-tag :style="{backgroundColor: `rgb(0, 0, ${scope.row.blue})`, color: 'white'}">
                    {{scope.row.blue}}
                </el-tag>
            </template>
        </el-table-column>
        <el-table-column label="Color Preview" width="auto">
            <template slot-scope="scope">
                <div class="color-preview" :style="{backgroundColor: `rgb(${scope.row.red}, ${scope.row.green}, ${scope.row.blue})`}">
                    RGB({{scope.row.red}}, {{scope.row.green}}, {{scope.row.blue}})
                </div>
            </template>
        </el-table-column>
        <el-table-column prop="addTime" label="Created Time" width="auto">
            <template slot-scope="scope">
                {{ dateformatter(scope.row.addTime) }}
            </template>
        </el-table-column>
        <el-table-column prop="lastUpdateTime" label="Updated Time" width="auto">
            <template slot-scope="scope">
                {{ dateformatter(scope.row.lastUpdateTime) }}
            </template>
        </el-table-column>
        <el-table-column label="Actions" width="auto">
            <template slot-scope="scope">
                <el-button type="primary" size="mini" @@click="editColor(scope.row)">Edit</el-button>
                <el-button type="warning" size="mini" @@click="randomizeColor(scope.row)">Random</el-button>
                <el-button type="danger" size="mini" @@click="deleteColor(scope.row)">Delete</el-button>
            </template>
        </el-table-column>
    </el-table>
    
    <div class="pagination-container">
        <el-pagination @@current-change="handleCurrentChange"
                       @@size-change="handleSizeChange"
                       :current-page="page.page"
                       :page-sizes="[10, 20, 30, 40]"
                       :page-size="page.size"
                       layout="sizes, prev, next, jumper"
                       :total="total"
                       background
                       style="margin-top: 20px">
        </el-pagination>
    </div>

    @* dialog for Add Color *@
    <el-dialog title="Add Color" :visible.sync="addFormDialogVisible" width="50%" :close-on-click-modal="false">
        <el-form :model="addForm" label-width="120px" :rules="addRules" ref="addForm">
            <el-form-item label="Red (R)" prop="red">
                <el-slider v-model="addForm.red" :min="0" :max="255" show-input></el-slider>
            </el-form-item>
            <el-form-item label="Green (G)" prop="green">
                <el-slider v-model="addForm.green" :min="0" :max="255" show-input></el-slider>
            </el-form-item>
            <el-form-item label="Blue (B)" prop="blue">
                <el-slider v-model="addForm.blue" :min="0" :max="255" show-input></el-slider>
            </el-form-item>
            <el-form-item label="Color Preview">
                <div class="color-preview-large" :style="{backgroundColor: `rgb(${addForm.red}, ${addForm.green}, ${addForm.blue})`}">
                    RGB({{addForm.red}}, {{addForm.green}}, {{addForm.blue}})
                </div>
            </el-form-item>
            <el-form-item label="Additional Notes" prop="additionNote">
                <el-input v-model="addForm.additionNote" type="textarea" :rows="3" placeholder="Enter additional notes for this color..."></el-input>
            </el-form-item>
            <el-form-item>
                <el-button @@click="randomizeForm" type="info">Random Color</el-button>
            </el-form-item>
        </el-form>
        <span slot="footer" class="dialog-footer">
            <el-button @@click="addFormDialogVisible = false">Cancel</el-button>
            <el-button type="primary" @@click="addColorSubmit">OK</el-button>
        </span>
    </el-dialog>

    @* dialog for Edit Color *@
    <el-dialog title="Edit Color" :visible.sync="editFormDialogVisible" width="50%" :close-on-click-modal="false">
        <el-form :model="editForm" label-width="120px" :rules="editRules" ref="editForm">
            <el-form-item label="Red (R)" prop="red">
                <el-slider v-model="editForm.red" :min="0" :max="255" show-input></el-slider>
            </el-form-item>
            <el-form-item label="Green (G)" prop="green">
                <el-slider v-model="editForm.green" :min="0" :max="255" show-input></el-slider>
            </el-form-item>
            <el-form-item label="Blue (B)" prop="blue">
                <el-slider v-model="editForm.blue" :min="0" :max="255" show-input></el-slider>
            </el-form-item>
            <el-form-item label="Color Preview">
                <div class="color-preview-large" :style="{backgroundColor: `rgb(${editForm.red}, ${editForm.green}, ${editForm.blue})`}">
                    RGB({{editForm.red}}, {{editForm.green}}, {{editForm.blue}})
                </div>
            </el-form-item>
            <el-form-item label="Additional Notes" prop="additionNote">
                <el-input v-model="editForm.additionNote" type="textarea" :rows="3" placeholder="Enter additional notes for this color..."></el-input>
            </el-form-item>
            <el-form-item>
                <el-button @@click="randomizeEditForm" type="info">Random Color</el-button>
            </el-form-item>
        </el-form>
        <span slot="footer" class="dialog-footer">
            <el-button @@click="editFormDialogVisible = false">Cancel</el-button>
            <el-button type="primary" @@click="editColorSubmit">OK</el-button>
        </span>
    </el-dialog>
</div>

@section scripts{
    <script src="~/js/Admin/Template_XncfName/databaseSampleIndex.js"></script>
} 