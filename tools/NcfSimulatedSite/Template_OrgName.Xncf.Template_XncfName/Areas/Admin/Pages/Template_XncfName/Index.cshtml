@page
@model Template_OrgName.Xncf.Template_XncfName.Areas.Template_XncfName.Pages.Index
@{
    ViewData["Title"] = "Template_XncfName Home";
    Layout = "_Layout_Vue";
}

@section breadcrumbs{
    <el-breadcrumb-item>Extension Modules</el-breadcrumb-item>
    <el-breadcrumb-item>Template_MenuName</el-breadcrumb-item>
    <el-breadcrumb-item>Home</el-breadcrumb-item>
}

<div>
    <el-container>
        <el-header class="module-header">
            <span class="start-title"> <i class="fa fa-dot-circle-o"></i>&nbsp;<span class="module-header-v">Home</span></span>
        </el-header>

        <!-- SideMenu can also be added here -->
        @*<el-aside width="200px">
            <el-menu background-color="#304156" default-active="1"
                        text-color="#bfcbd9" active-text-color="#409eff">
                @(await Html.PartialAsync("_SideMenu"))
            </el-menu>
        </el-aside>*@
        <el-main>
            <h3>@Model.XncfRegister.MenuName / @Model.XncfRegister.Name</h3>
            <h4>@Model.XncfRegister.Description</h4>
            <br />
            <i>This module was auto-generated</i>
        </el-main>
    </el-container>
</div>


@section scripts{
    <script>
        new Vue({
            el: "#app"
        });
    </script>
}
