@page
@model Senparc.Xncf.DynamicData.Areas.Admin.Pages.DynamicData.LayoutSetModel


@inject Microsoft.Extensions.Localization.IStringLocalizerFactory LocalizerFactory
@{
    var AR = LocalizerFactory.Create("Senparc.Areas.Admin.Resources.AdminResource", "Senparc.Areas.Admin");
    ViewData["Title"] = AR["DynamicData.LayoutTitle"];
    Layout = "_Layout_Vue";
}

@section Style {
    <link href="~/css/DynamicData/layoutSet.css" rel="stylesheet" />
    <meta http-equiv="Content-Security-Policy" content="upgrade-insecure-requests">
}

@section breadcrumbs {
    <el-breadcrumb-item>@AR["Common.ExtensionModules"]</el-breadcrumb-item>
    <el-breadcrumb-item>@AR["DynamicData.ModuleName"]</el-breadcrumb-item>
    <el-breadcrumb-item>@AR["DynamicData.DataSheetSetTitle"]</el-breadcrumb-item>
}

<el-container style="height: 100%;flex-direction:column;flex-wrap: nowrap;">
    <div class="layoutSet-nav df-wn flex-ac">
        <div class="nav-titlebox df-wn flex-ac flex-jc">
            <template v-if="isEditLayoutName">
                <el-input ref="inputLayoutName" v-model.trim="layoutName" :size="elSize" placeholder="@AR["DynamicData.PleaseInputLayoutName"]"
                    style="width:310px" @@blur="handleBlurLayoutName"></el-input>
            </template>
            <template v-else>
                <span class="title-text" :class="{'title-text_value':!!layoutName}">{{ layoutName || '请输入布局名称' }}</span>
                <i class="el-icon-edit editLayoutName-btn" @@click="handleEditLayoutName"></i>
            </template>
        </div>
        <div class="nav-btnbox df-wn flex-ac flex-je">
            <el-button type="primary" :size="elSize" @@click="handleCodeView">@AR["DynamicData.CodeView"]</el-button>
            <el-button type="primary" :size="elSize" icon="el-icon-caret-right" @@click="handlePreview"></el-button>
            <el-button type="primary" :size="elSize" icon="el-icon-s-promotion" @@click="handleRelease">@AR["Common.Publish"]</el-button>
        </div>
    </div>
    @* 详情内容 *@
    <el-container style="flex-wrap: nowrap;">
        <div class="layoutSet-main">
            @* 菜单 *@
            <div class="main_header df-wn flex-ac">
                <div class="menu-area">
                    <div class="menu-list df-wn flex-ac">
                        <div v-for="(item,index) in layoutMenuList" :key="index" class="menu-item"
                            @@click.self="handleSwitchMenu(index)">
                            <template v-if="item.isEditName">
                                <el-input ref="inputMenuName" v-model.trim="item.name" :size="elSize"
                                    placeholder="@AR["DynamicData.PleaseInputMenuName"]" style="width:100px"
                                    @@blur="handleBlurMenuName(item)"></el-input>
                            </template>
                            <template v-else>
                                <span class="title-text">{{ item.name }}</span>
                                <i class="el-icon-edit editMenuName-btn"
                                    @@click.stop="handleEditMenuName(item,index)"></i>
                            </template>
                        </div>
                    </div>
                </div>
                <div class="menu-newbtn" @@click="handleAddMenu">
                    <i class="el-icon-plus"></i>@AR["Auto.UI.ba750e6e3022"]
                </div>
            </div>
            @* 主体操作区域 *@
            <div class="main_content">
                @* 全局按钮 *@
                <template>
                    <div class="globalButton-area"></div>
                </template>
                @* 组件区域 *@
                <div v-for="(item,index) in layoutComponentsList" :key="index" class="component-area"
                    :class="{activeComponentArea:index === layoutComponentActive}" :draggable="true"
                    @@dragstart="handleDragstart(index)" @@dragenter="handleDragenter($event, index, 'layoutComponent')"
                    @@dragover="handleDragover" @@click="handleSelectComponent(item,index)">
                    <template v-if="item.componentType === 'table'">
                        <div v-if="item.pagConfig&&item.pagConfig.enable&&item.pagConfig.position.includes('top')"
                            class="df-wn flex-ac" :class="[positionClassOpt[item.pagConfig.position]]">
                            <el-pagination :pager-count="item.pagConfig.pagerCount"
                                :page-sizes="item.pagConfig.pageSizes" :page-size="item.pagConfig.pageSizes[0]"
                                :layout="item.pagConfig.layoutStr" :current-page="1" :total="100">
                            </el-pagination>
                        </div>
                        <div v-if="item.columnData&&item.columnData.length" class="w-table" @@click.stop>
                            @* :height="item.tableConfig.height"
                            :max-height="item.tableConfig.maxHeight"
                            :style="{ width: parseInt(item.tableConfig.width)+'px' }" *@
                            <el-table :data="item.tableMockData"
                                :border="item.tableConfig ? item.tableConfig.border : false"
                                :cell-class-name="cellClassName" :header-cell-class-name="headerCellClassName">
                                <el-table-column v-for="(col, index) in item.columnData" :key="index"
                                    :column-key="col.columnkey" :prop="col.field" :label="col.name"
                                    :width="col.columnWidth" :render-header="renderHeader">
                                    @* 自定义列 按钮 *@
                                    <div v-if="col.property === 'customColumn'"
                                        class="df flex-as table_customColumn_btnBox">
                                        <span v-for="(btn,bindex) in col.btnList" class="table_customColumn_btn"
                                            @@click="customColumnBtnSelect(btn,bindex)">
                                            {{ btn.name }}
                                        </span>
                                    </div>
                                </el-table-column>
                            </el-table>
                        </div>
                        <div v-if="item.pagConfig&&item.pagConfig.enable&&item.pagConfig.position.includes('bottom')"
                            class="df-wn flex-ac" :class="[positionClassOpt[item.pagConfig.position]]">
                            <el-pagination :pager-count="item.pagConfig.pagerCount"
                                :page-sizes="item.pagConfig.pageSizes" :page-size="item.pagConfig.pageSizes[0]"
                                :layout="item.pagConfig.layoutStr" :current-page="1" :total="100">
                            </el-pagination>
                        </div>
                    </template>
                    <template v-if="item.componentType === 'form'">
                        @* :model="ruleForm" ref="ruleForm" :rules="rules" *@
                        <el-form v-if="item.columnData&&item.columnData.length" :label-position="item.formConfig ? item.formConfig.labelPosition : 'left'" label-width="100px" class="demo-ruleForm">
                            <el-form-item v-for="(fItem,fIndex) in item.columnData" :key="fIndex" :label="fItem.name"
                                :prop="fItem.field" @@click.native.stop="handleFormItemMouseDown(index,fIndex)">
                                @* 输入框 *@
                                <el-input v-if="fItem.formItemType === 'input'" :type="fItem.type" v-model="fItem.value" :placeholder="fItem.placeholder"></el-input>
                                @* 开关 *@
                                <el-switch v-if="fItem.formItemType === 'switch'" v-model="fItem.value"></el-switch>
                                @* 下拉选择 *@
                                <el-select v-if="fItem.formItemType === 'select'" v-model="fItem.value"
                                    :placeholder="fItem.placeholder">
                                    <el-option v-for="(optItem,optIndex) in fItem.optionData" :key="optIndex"
                                        :label="optItem.label" :value="optItem.value"></el-option>
                                </el-select>
                                @* 固定时间点 *@
                                <el-time-select v-if="fItem.formItemType === 'timeSelect'" v-model="fItem.value" :picker-options="fItem.pickerOptions" :placeholder="fItem.placeholder">
                                </el-time-select>
                                @* 任意时间点 *@
                                <el-time-picker v-if="fItem.formItemType === 'timePicker'" v-model="fItem.value" :placeholder="fItem.placeholder"></el-time-picker>
                                @* 日期 时间 *@
                                <el-date-picker v-if="fItem.formItemType === 'date'" :type="fItem.type" v-model="fItem.value" :placeholder="fItem.placeholder"></el-date-picker>
                                @* 复选框 *@
                                <el-checkbox-group v-if="fItem.formItemType === 'checkbox'" v-model="fItem.value">
                                    <el-checkbox v-for="(checkItem,checkIndex) in fItem.optionData"
                                        :label="checkItem.value" :key="checkIndex">
                                        {{ checkItem.label }}
                                    </el-checkbox>
                                </el-checkbox-group>
                                @* 单选框 *@
                                <el-radio-group v-if="fItem.formItemType === 'radio'" v-model="fItem.value">
                                    <el-radio v-for="(radioItem,radioIndex) in fItem.optionData"
                                        :label="radioItem.value" :key="radioIndex">
                                        {{ radioItem.label }}
                                </el-radio>
                                </el-radio-group>
                            </el-form-item>
                            <el-form-item>
                            <el-button type="primary" @@click.stop="handleSubmitBtnEdit(item)">@AR["Common.Submit"]</el-button>
                            @* <el-button @@click="resetForm('ruleForm')">@AR["Common.Reset"]</el-button> *@
                            </el-form-item>
                        </el-form>
                    </template>
                    @* 组件占位 *@
                    <div v-if="componentOccupantShow(item)" class="occupant-area df-wn flex-ac flex-jc">
                        <img src="/image/DynamicData/icon-select_active.png" alt="" class="icon-select" />
                        <span style="user-select:none;">@AR["DynamicData.ClickToAddAttribute"]</span>
                    </div>
                    @* 上下移动 *@
                    @* <i class="el-icon-circle-plus upper_add-Component" @@click="handleAddComponent(index)"></i>
                    <i class="el-icon-circle-plus down_add-Component" @@click="handleAddComponent(index+1)"></i> *@
                </div>

                @* 添加组件提示 *@
                <div class="add-Component_Tips df-wn flex-ac flex-jc" @@click="handleAddComponent()">
                    <img src="/image/DynamicData/icon-select.png" alt="" class="icon-select" />
                    <span style="user-select:none;">@AR["DynamicData.ClickToAddComponent"]</span>
                </div>
            </div>
        </div>
        @* 侧边栏 *@
        <div class="layoutSet-aside">
            <el-tabs v-model="tabsOverallActiveName" :before-leave="handleTabsLeave"
                @@tab-click="handleTabsClickOverall">
                <el-tab-pane label="@AR["Common.Add"]" name="first">
                    <div class="tabpane">
                        <div class="operation-title">@AR["Auto.UI.bb79667f3703"]</div>
                        <div class="operation-area df flex-ac">
                            <div class="assembBtn df-wn flex-ac flex-jc"
                                :class="{'btnDisabled':addAssembBtnDisabled('table')}"
                                @@click="handleAddComponent('table')">
                                <img src="/image/DynamicData/icon-table.png" alt="" class="btn-iconImg" />
                                <span>@AR["DynamicData.DataTable"]</span>
                            </div>
                            <div class="assembBtn df-wn flex-ac flex-jc"
                                :class="{'btnDisabled':addAssembBtnDisabled('form')}"
                                @@click="handleAddComponent('form')">
                                <img src="/image/DynamicData/icon-form.png" alt="" class="btn-iconImg" />
                                <span>@AR["DynamicData.DataDetail"]</span>
                            </div>
                            <div class="assembBtn df-wn flex-ac flex-jc"
                                :class="{'btnDisabled':addAssembBtnDisabled('btn')}"
                                @@click="handleAddComponent('btn')">
                                <span>@AR["DynamicData.CustomButton"]</span>
                            </div>
                        </div>
                    </div>
                </el-tab-pane>
                <el-tab-pane label="@AR["Auto.UI.e366ccf1556c"]" name="second">
                    @* 表格设置管理 *@
                    <div class="tabpane">
                        <div class="subsection-container df-wn flex-ac flex-jc">
                            <div class="subsection-item" :class="{'subsection-item_avtive':setUpActiveName === 'first'}"
                                @@click="handleSubsectionUpdate('setUpActiveName','first')">@AR["Auto.UI.24d67862f87f"]</div>
                            <div class="subsection-item"
                                :class="{'subsection-item_avtive':setUpActiveName === 'second'}"
                                @@click="handleSubsectionUpdate('setUpActiveName','second')">@AR["Auto.UI.39003734d1d7"]</div>
                        </div>
                        @* 属性设置 *@
                        <template v-if="setUpActiveName === 'first'">
                            @* 表格|表单 表和列属性 设置 *@
                            <template v-if="['table','form'].includes(layoutComponentActiveType)">
                                @* 表格提示 *@
                                <div v-if="!columnForm.dataSheet" class="tips-container df-wn flex-ac">
                                    <i class="el-icon-warning-outline"></i>
                                    <span class="tipsText">
                                        @AR["Auto.UI.920a57a2d11b"]
                                    </span>
                                </div>
                                @* 列管理 *@
                                <div class="operation-title" style="margin-top:20px;">@AR["DynamicData.ColumnManagement"]</div>
                                <el-form :model="columnForm" :size="elSize" label-position="top" label-width="80px" class="form-container">
                                    <el-form-item label="@AR["DynamicData.SelectDataSheet"]" prop="dataSheet">
                                        <el-select v-model="columnForm.dataSheet" style="width:100%"
                                            placeholder="@AR["DynamicData.PleaseSelectDataSheet"]">
                                            <el-option label="@AR["DynamicData.DataSheetText"]" value="shanghai"></el-option>
                                            <el-option label="@AR["Auto.UI.8a2d99eb1619"]" value="beijing"></el-option>
                                        </el-select>
                                    </el-form-item>
                                    <el-form-item label="@AR["DynamicData.SelectColumn"]" prop="columnData">
                                        <table class="table-container">
                                            <thead class="table-head">
                                                <tr>
                                                    <th style="width:150px">
                                                        <el-checkbox v-model="columnForm.allChecked"
                                                            :disabled="!columnForm.columnData.length"
                                                            @@change="handleColumnAllCheckedChange">@AR["Auto.UI.9caecd931b95"]</el-checkbox>
                                                    </th>
                                                    <th>
                                                        @AR["Auto.UI.185f7bf64751"]
                                                    </th>
                                                    <th style="width:30px"></th>
                                                </tr>
                                            </thead>
                                            <tbody class="table-body">
                                                <tr v-for="(tbody_td,tr) in columnForm.columnData" :key="'tbody-tr-'+tr"
                                                    style="transition: transform .3s;" :draggable="true"
                                                    @@dragstart="handleDragstart(tr)"
                                                    @@dragenter="handleDragenter($event, index, 'column')"
                                                    @@dragover="handleDragover">
                                                    <template v-if="tbody_td.iscustom">
                                                        <td colspan="2" style="width:150px;">
                                                            <el-checkbox v-model="tbody_td.checked"
                                                                @@change="handleColumnCheckedChange">{{ tbody_td.name
                                                                }}</el-checkbox>
                                                        </td>
                                                        <td style="width:30px">
                                                            <img src="/image/DynamicData/icon-move.png" alt=""
                                                                class="moveIcon" />
                                                    </template>
                                                    <template v-else>
                                                        <td style="width:150px;">
                                                            <el-checkbox v-model="tbody_td.checked"
                                                                @@change="handleColumnCheckedChange">{{ tbody_td.name
                                                                }}</el-checkbox>
                                                        </td>
                                                        <td>{{ tbody_td.dataType }}</td>
                                                        <td style="width:30px">
                                                            <img src="/image/DynamicData/icon-move.png" alt=""
                                                                class="moveIcon" />
                                                        </td>
                                                    </template>
                                                </tr>
                                                <tr class="addColumn-btn">
                                                    <td colspan="3" style="position:relative;">
                                                        <el-popover placement="left" width="400" trigger="click"
                                                            v-model="addColumnVisible">
                                                            <div class="popover-bodyBox">
                                                                <div class="popover-title">@AR["Auto.UI.49198f84cea6"]</div>
                                                                <el-form :model="addColumnForm" :size="elSize"
                                                                    label-position="top" label-width="80px"
                                                                    class="form-container">
                                                                    <template
                                                                        v-if="layoutComponentActiveType === 'table'">
                                                                        <el-form-item label="@AR["DynamicData.ColumnProperty"]">
                                                                            <el-select v-model="addColumnForm.property"
                                                                                style="width:100%" placeholder="@AR["Common.PleaseSelect"]">
                                                                                <el-option label="@AR["DynamicData.NormalColumn"]"
                                                                                    value="normalColumn"></el-option>
                                                                                <el-option label="@AR["DynamicData.ActionColumn"]"
                                                                                    value="customColumn"></el-option>
                                                                            </el-select>
                                                                        </el-form-item>
                                                                        <el-form-item label="@AR["DynamicData.ColumnTitle"]">
                                                                            <el-input v-model.trim="addColumnForm.name"
                                                                                :size="elSize"
                                                                                placeholder="@AR["DynamicData.PleaseInputColumnTitle"]"></el-input>
                                                                        </el-form-item>
                                                                        <el-form-item label="@AR["DynamicData.BindField"]">
                                                                            <el-select v-model="addColumnForm.field"
                                                                                style="width:100%"
                                                                                placeholder="@AR["DynamicData.PleaseSelectBindField"]">
                                                                                <el-option label="name"
                                                                                    value="name"></el-option>
                                                                                <el-option label="age"
                                                                                    value="age"></el-option>
                                                                            </el-select>
                                                                        </el-form-item>
                                                                        <el-form-item label="@AR["DynamicData.DisplayContent"]">
                                                                            <el-select
                                                                                v-model="addColumnForm.displayContent"
                                                                                style="width:100%"
                                                                                placeholder="@AR["DynamicData.PleaseSelectDisplayContent"]">
                                                                                <el-option label="@AR["Auto.UI.60d0458ac6eb"]"
                                                                                    value="姓名"></el-option>
                                                                                <el-option label="@AR["Auto.UI.a01a9963238d"]"
                                                                                    value="年龄"></el-option>
                                                                            </el-select>
                                                                        </el-form-item>
                                                                        <el-form-item label="@AR["DynamicData.DataFormat"]">
                                                                            <el-select v-model="addColumnForm.dataType"
                                                                                style="width:100%"
                                                                                placeholder="@AR["DynamicData.PleaseSelectDataFormat"]">
                                                                                <el-option label="number"
                                                                                    value="number"></el-option>
                                                                                <el-option label="string"
                                                                                    value="string"></el-option>
                                                                            </el-select>
                                                                        </el-form-item>
                                                                        <el-form-item label="@AR["DynamicData.ColumnWidth"]">
                                                                            <el-input
                                                                                v-model.trim="addColumnForm.columnWidth"
                                                                                :size="elSize"
                                                                                placeholder="@AR["DynamicData.PleaseInputColumnWidth"]"></el-input>
                                                                            @* <el-select
                                                                            v-model="addColumnForm.columnWidth"
                                                                            style="width:100%" placeholder="@AR["Auto.UI.5ab94c2807db"]">
                                                                            <el-option label="@AR["DynamicData.DataSheetText"]"
                                                                            value="shanghai"></el-option>
                                                                            <el-option label="@AR["Auto.UI.8a2d99eb1619"]"
                                                                            value="beijing"></el-option>
                                                                            </el-select> *@
                                                                        </el-form-item>
                                                                        <el-form-item label="@AR["DynamicData.Alignment"]">
                                                                            <el-select v-model="addColumnForm.alignment"
                                                                                style="width:100%"
                                                                                placeholder="@AR["DynamicData.PleaseSelectAlignment"]">
                                                                                <el-option label="@AR["DynamicData.AlignLeft"]"
                                                                                    value="left"></el-option>
                                                                                <el-option label="@AR["DynamicData.AlignRight"]"
                                                                                    value="right"></el-option>
                                                                                <el-option label="@AR["Auto.UI.b7b6bfcba91b"]"
                                                                                    value="center"></el-option>
                                                                            </el-select>
                                                                        </el-form-item>
                                                                        <el-form-item>
                                                                            <el-checkbox
                                                                                v-model="addColumnForm.isSort">@AR["DynamicData.AllowSort"]</el-checkbox>
                                                                            <el-checkbox
                                                                                v-model="addColumnForm.isExport">@AR["DynamicData.AllowExport"]</el-checkbox>
                                                                            <el-checkbox
                                                                                v-model="addColumnForm.isEdit">@AR["DynamicData.AllowEdit"]</el-checkbox>
                                                                            <el-checkbox
                                                                                v-model="addColumnForm.isDelete">@AR["DynamicData.AllowDelete"]</el-checkbox>
                                                                        </el-form-item>
                                                                    </template>
                                                                    <template v-if="layoutComponentActiveType === 'form'">
                                                                        <el-form-item label="@AR["DynamicData.BindField"]">
                                                                            <el-select v-model="addColumnForm.field"
                                                                                style="width:100%"
                                                                                placeholder="@AR["DynamicData.PleaseSelectBindField"]">
                                                                                <el-option label="name"
                                                                                    value="name"></el-option>
                                                                                <el-option label="age"
                                                                                    value="age"></el-option>
                                                                            </el-select>
                                                                        </el-form-item>
                                                                        <el-form-item label="@AR["DynamicData.SelectComponent"]">
                                                                            <el-select v-model="addColumnForm.formItemType"
                                                                                style="width:100%"
                                                                                placeholder="@AR["DynamicData.PleaseSelectComponent"]" @@change="handleFormItemTypeChange">
                                                                                <el-option v-for="(fitItem,fitIndex) in formItemOpt" :key="fitIndex" :label="fitItem.label" :value="fitItem.value" />
                                                                            </el-select>
                                                                        </el-form-item>
                                                                        <el-form-item v-if="formItemTypeOptChildren.length" label="@AR["DynamicData.ComponentType"]">
                                                                            <el-select v-model="addColumnForm.type"
                                                                                style="width:100%"
                                                                                placeholder="@AR["DynamicData.PleaseSelectComponentType"]">
                                                                                <el-option v-for="(fitItem,fitIndex) in formItemTypeOptChildren" :key="fitIndex" :label="fitItem.label" :value="fitItem.value" />
                                                                            </el-select>
                                                                        </el-form-item>
                                                                        <el-form-item label="@AR["DynamicData.FieldName"]">
                                                                            <el-input v-model.trim="addColumnForm.name"
                                                                                :size="elSize"
                                                                                placeholder="@AR["DynamicData.PleaseInputFieldName"]"></el-input>
                                                                        </el-form-item>
                                                                        @* 选择项 *@
                                                                        <el-form-item v-if="['checkbox', 'radio', 'select'].includes(addColumnForm.formItemType)" label="@AR["DynamicData.Option"]">
                                        <el-select v-model="addColumnForm.optionDataType"
                                            style="width:100%;margin-bottom:10px" placeholder="@AR["Common.PleaseSelect"]">
                                            <el-option label="@AR["DynamicData.DataSet"]" value="dataSheet"></el-option>
                                            <el-option label="@AR["Auto.UI.f1d4ff50f382"]" value="customData"></el-option>
                                        </el-select>
                                        <el-form-item v-if="addColumnForm.optionDataType === 'dataSheet'" label="@AR["DynamicData.SelectDataSheet"]">
                                            <el-select v-model="addColumnForm.dataSheet" style="width:100%"
                                                placeholder="@AR["DynamicData.PleaseSelectDataSheet"]">
                                                <el-option label="@AR["DynamicData.DataSheetText"]" value="shujubiao"></el-option>
                                                <el-option label="@AR["Auto.UI.8a2d99eb1619"]" value="shujubiao1"></el-option>
                                            </el-select>
                                        </el-form-item>
                                        <template v-if="addColumnForm.optionDataType === 'customData'">
                                            <el-popover v-for="(item,index) in addColumnForm.optionData" :key="index"
                                            placement="left" width="400" trigger="click">
                                            <div class="popover-bodyBox">
                                                <div class="popover-title">@AR["DynamicData.OptionSettings"]</div>
                                                <div class="popover-list df-wn flex-dc">
                                                    <div class="popover-list-item df-wn flex-ac">
                                                        <div class="line-label">@AR["Auto.UI.7a391b31caf7"]</div>
                                                        <el-input v-model="item.label"
                                                            placeholder="@AR["Common.PleaseInputContent"]"></el-input>
                                                    </div>
                                                    <div class="popover-list-item df-wn flex-ac">
                                                        <div class="line-label">@AR["Auto.UI.1abfae8ea5cd"]</div>
                                                        <el-input v-model="item.value"
                                                            placeholder="@AR["Common.PleaseInputContent"]"></el-input>
                                                    </div>
                                                </div>
                                            </div>
                                            <div slot="reference" class="sortList-box df-wn flex-dc">
                                                <div class="sortitem-box df-wn flex-ac">
                                                    <img src="/image/DynamicData/icon-move.png" alt=""
                                                        class="moveIcon" />
                                                    <div class="sortitemtext">{{ item.label&&item.value ? `${item.label}` : '请添加选项' }}</div>
                                                    <i class="el-icon-remove-outline"
                                                        style="cursor:pointer;color:#a6a6a6;"
                                                        @@click.stop="handleDeleteOptionData(index)"></i>
                                                </div>
                                            </div>
                                        </el-popover>
                                        <div class="addsort-box df-wn flex-ac" @@click="handleAddOptionData">
                                            <i class="el-icon-circle-plus-outline"></i>
