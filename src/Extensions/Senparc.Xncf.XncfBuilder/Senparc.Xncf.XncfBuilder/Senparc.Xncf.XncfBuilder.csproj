    <RepositoryUrl>https://github.com/NeuCharFramework/NcfPackageSources</RepositoryUrl>
    <Configurations>Debug;Release;Test;TemplateRelease</Configurations>
    <!-- Visual Studio 特定设置 -->
    <DisableImplicitNuGetFallbackFolder>true</DisableImplicitNuGetFallbackFolder>
    <RestorePackagesWithLockFile>false</RestorePackagesWithLockFile>
    <!-- Source Generator 设置 -->
    <EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>
    <CompilerGeneratedFilesOutputPath>Generated</CompilerGeneratedFilesOutputPath>
    <!-- Visual Studio Source Generator 兼容性设置 -->
    <EnableNETAnalyzers>true</EnableNETAnalyzers>
    <RunAnalyzersDuringLiveAnalysis>true</RunAnalyzersDuringLiveAnalysis>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Release' OR '$(Configuration)'=='TemplateRelease'">
    <OutputPath>..\..\..\BuildOutPut</OutputPath>
    <DocumentationFile>..\..\..\BuildOutPut\Senparc.Xncf.XncfBuilder.XML</DocumentationFile>
    <DefineConstants>$(DefineConstants);RELEASE</DefineConstants>
    <Optimize>true</Optimize>
    <DebugType>pdbonly</DebugType>
    <ErrorReport>prompt</ErrorReport>
    <CodeAnalysisRuleSet>MinimumRecommendedRules.ruleset</CodeAnalysisRuleSet>
    <!-- CI/Release 使用仓库内已检入的 Generated 文件，避免 Source Generator 在 Agent 上零输出 -->
    <UseCheckedInXncfBuilderGeneratedCode>true</UseCheckedInXncfBuilderGeneratedCode>
  </PropertyGroup>
  <ItemGroup>
    <Compile Remove="ACL\**" />
    <Compile Remove="Generated\**" Condition="'$(UseCheckedInXncfBuilderGeneratedCode)' != 'true'" />
    <EmbeddedResource Remove="ACL\**" />
