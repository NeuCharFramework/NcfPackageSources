@page
@model Template_OrgName.Xncf.Template_XncfName.Areas.Template_XncfName.Pages.Index
@inject Microsoft.Extensions.Localization.IStringLocalizerFactory LocalizerFactory
@{    var AR = LocalizerFactory.Create("Senparc.Areas.Admin.Resources.AdminResource", "Senparc.Areas.Admin");

    ViewData["Title"] = AR["Auto.UI.b2e495ab583e"];
    Layout = "_Layout_Vue";
}

@section breadcrumbs{
    <el-breadcrumb-item>@AR["Common.ExtensionModules"]</el-breadcrumb-item>
    <el-breadcrumb-item>Template_MenuName</el-breadcrumb-item>
    <el-breadcrumb-item>@AR["Common.Home"]</el-breadcrumb-item>
}

<div>
    <el-container>
        <el-header class="module-header">
            <span class="start-title"> <i class="fa fa-dot-circle-o"></i>&nbsp;<span class="module-header-v">@AR["Common.Home"]</span></span>
        </el-header>

        <!-- 此处也可以加 SideMenu -->
        @*<el-aside width="200px">
            <el-menu background-color="#304156" default-active="1"
                        text-color="#bfcbd9" active-text-color="#409eff">
                @(await Html.PartialAsync("_SideMenu"))
            </el-menu>
        </el-aside>*@
        <el-main>
            <h3>@Model.XncfRegister.MenuName / @Model.XncfRegister.Name</h3>
            <h4>@Model.XncfRegister.Description</h4>
            <br />
            <i>@AR["Common.AutoGeneratedModule"]</i>
        </el-main>
    </el-container>
</div>


@section scripts{
    <script>
        new Vue({
            el: "#app"
        });
    </script>
}
