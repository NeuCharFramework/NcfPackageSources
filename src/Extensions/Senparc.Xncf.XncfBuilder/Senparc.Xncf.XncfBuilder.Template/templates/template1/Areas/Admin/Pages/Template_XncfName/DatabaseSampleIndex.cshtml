@page
@model Template_OrgName.Xncf.Template_XncfName.Areas.Template_XncfName.Pages.DatabaseSampleIndex
@inject Microsoft.Extensions.Localization.IStringLocalizerFactory LocalizerFactory
@{    var AR = LocalizerFactory.Create("Senparc.Areas.Admin.Resources.AdminResource", "Senparc.Areas.Admin");
    var CR = LocalizerFactory.Create("Senparc.Ncf.XncfBase.Resources.CommonResource", "Senparc.Ncf.XncfBase");

    ViewData["Title"] = AR["Auto.UI.6d8884ca4608"];
    Layout = "_Layout_Vue";
}

@section Style {
    <link href="~/css/Admin/Template_XncfName/databaseSampleIndex.css" rel="stylesheet" />
}

@section breadcrumbs {
    <el-breadcrumb-item>@CR["Common.ExtensionModules"]</el-breadcrumb-item>
    <el-breadcrumb-item>Template_MenuName</el-breadcrumb-item>
    <el-breadcrumb-item>@AR["Auto.UI.6d8884ca4608"]</el-breadcrumb-item>
}

<div>
    <div class="filter-container">
        <el-button type="primary" icon="el-icon-plus" size="small" @@click="addColor">@AR["Auto.UI.95e9696b0063"]</el-button>
        <el-button type="success" icon="el-icon-refresh" size="small" @@click="refreshList">@AR["Auto.UI.694fc5efa9e1"]</el-button>
        <el-button type="info" icon="el-icon-info" size="small" @@click="debugInfo">@AR["Auto.UI.a9cfab552ace"]</el-button>
    </div>

    <!-- 调试信息显示 -->
    <div v-if="showDebug" style="background: #f0f9ff; border: 1px solid #0ea5e9; padding: 10px; margin: 10px 0; border-radius: 4px;">
        <h4>@AR["Auto.UI.3360f99a14aa"]</h4>
        <p><strong>@AR["Auto.UI.5f2aed06c984"]</strong> {{ tableData ? tableData.length : 'null/undefined' }}</p>
        <p><strong>total:</strong> {{ total }}</p>
        <p><strong>tableLoading:</strong> {{ tableLoading }}</p>
        <p><strong>@AR["Auto.UI.8ffc5c2041df"]</strong> {{ $el ? '是' : '否' }}</p>
        <div v-if="tableData && tableData.length > 0">
            <strong>@AR["Auto.UI.11170e91e4c1"]</strong>
            <pre>{{ JSON.stringify(tableData[0], null, 2) }}</pre>
        </div>
        
        <!-- 简化数据显示测试 -->
        <div style="background: #fff3cd; border: 1px solid #ffc107; padding: 10px; margin: 10px 0; border-radius: 4px;">
            <h5>@AR["Auto.UI.cc7e887f9ac8"]</h5>
            <div v-for="(item, index) in tableData" :key="item.id || index" style="border: 1px solid #ccc; margin: 5px 0; padding: 5px;">
                <strong>ID:</strong> {{item.id}} | 
                <strong>RGB:</strong> {{item.red}},{{item.green}},{{item.blue}} | 
                <strong>@AR["Auto.UI.37485657d8bf"]</strong> {{item.addTime}}
            </div>
            <p v-if="!tableData || tableData.length === 0" style="color: red;">
                <strong>@AR["Auto.UI.ac22b836c8aa"]</strong>
            </p>
        </div>
    </div>

    <el-table :data="tableData" v-loading="tableLoading" border>
        <el-table-column prop="id" label="ID" width="auto"></el-table-column>
        <el-table-column prop="red" label="@AR["Auto.UI.d5279a14c2e1"]" width="auto">
            <template slot-scope="scope">
                <el-tag :style="{backgroundColor: `rgb(${scope.row.red}, 0, 0)`, color: 'white'}">
                    {{scope.row.red}}
                </el-tag>
            </template>
        </el-table-column>
        <el-table-column prop="green" label="@AR["Auto.UI.5785f658c90c"]" width="auto">
            <template slot-scope="scope">
                <el-tag :style="{backgroundColor: `rgb(0, ${scope.row.green}, 0)`, color: 'white'}">
                    {{scope.row.green}}
                </el-tag>
            </template>
        </el-table-column>
        <el-table-column prop="blue" label="@AR["Auto.UI.1041efcc6d87"]" width="auto">
            <template slot-scope="scope">
                <el-tag :style="{backgroundColor: `rgb(0, 0, ${scope.row.blue})`, color: 'white'}">
                    {{scope.row.blue}}
                </el-tag>
            </template>
        </el-table-column>
        <el-table-column label="@AR["Auto.UI.d8d8e59e5198"]" width="auto">
            <template slot-scope="scope">
                <div class="color-preview" :style="{backgroundColor: `rgb(${scope.row.red}, ${scope.row.green}, ${scope.row.blue})`}">
                    RGB({{scope.row.red}}, {{scope.row.green}}, {{scope.row.blue}})
                </div>
            </template>
        </el-table-column>
        <el-table-column prop="addTime" label="@AR["Auto.UI.eca37cb0726c"]" width="auto">
            <template slot-scope="scope">
                {{ dateformatter(scope.row.addTime) }}
            </template>
        </el-table-column>
        <el-table-column prop="lastUpdateTime" label="@AR["Auto.UI.a001a226fdc3"]" width="auto">
            <template slot-scope="scope">
                {{ dateformatter(scope.row.lastUpdateTime) }}
            </template>
        </el-table-column>
        <el-table-column label="@CR["Common.Action"]" width="auto">
            <template slot-scope="scope">
                <el-button type="primary" size="mini" @@click="editColor(scope.row)">@CR["Common.Edit"]</el-button>
                <el-button type="warning" size="mini" @@click="randomizeColor(scope.row)">@CR["Common.Random"]</el-button>
                <el-button type="danger" size="mini" @@click="deleteColor(scope.row)">@CR["Common.Delete"]</el-button>
            </template>
        </el-table-column>
    </el-table>
    
    <div class="pagination-container">
        <el-pagination @@current-change="handleCurrentChange"
                       @@size-change="handleSizeChange"
                       :current-page="page.page"
                       :page-sizes="[10, 20, 30, 40]"
                       :page-size="page.size"
                       layout="sizes, prev, next, jumper"
                       :total="total"
                       background
                       style="margin-top: 20px">
        </el-pagination>
    </div>

    @* dialog for 添加颜色 *@
    <el-dialog title="@AR["Auto.UI.95e9696b0063"]" :visible.sync="addFormDialogVisible" width="50%" :close-on-click-modal="false">
        <el-form :model="addForm" label-width="120px" :rules="addRules" ref="addForm">
            <el-form-item label="@AR["Auto.UI.d5279a14c2e1"]" prop="red">
                <el-slider v-model="addForm.red" :min="0" :max="255" show-input></el-slider>
            </el-form-item>
            <el-form-item label="@AR["Auto.UI.5785f658c90c"]" prop="green">
                <el-slider v-model="addForm.green" :min="0" :max="255" show-input></el-slider>
            </el-form-item>
            <el-form-item label="@AR["Auto.UI.1041efcc6d87"]" prop="blue">
                <el-slider v-model="addForm.blue" :min="0" :max="255" show-input></el-slider>
            </el-form-item>
            <el-form-item label="@AR["Auto.UI.d8d8e59e5198"]">
                <div class="color-preview-large" :style="{backgroundColor: `rgb(${addForm.red}, ${addForm.green}, ${addForm.blue})`}">
                    RGB({{addForm.red}}, {{addForm.green}}, {{addForm.blue}})
                </div>
            </el-form-item>
            <el-form-item label="@AR["Auto.UI.133820eee7f5"]" prop="additionNote">
                <el-input v-model="addForm.additionNote" type="textarea" :rows="3" placeholder="@AR["Auto.UI.c26ad5de6440"]"></el-input>
            </el-form-item>
            <el-form-item>
                <el-button @@click="randomizeForm" type="info">@AR["Auto.UI.5565d87f760e"]</el-button>
            </el-form-item>
        </el-form>
        <span slot="footer" class="dialog-footer">
            <el-button @@click="addFormDialogVisible = false">@CR["Common.Cancel"]</el-button>
            <el-button type="primary" @@click="addColorSubmit">@CR["Common.Confirm"]</el-button>
        </span>
    </el-dialog>

    @* dialog for 编辑颜色 *@
    <el-dialog title="@AR["Auto.UI.1e852c38a90d"]" :visible.sync="editFormDialogVisible" width="50%" :close-on-click-modal="false">
        <el-form :model="editForm" label-width="120px" :rules="editRules" ref="editForm">
            <el-form-item label="@AR["Auto.UI.d5279a14c2e1"]" prop="red">
                <el-slider v-model="editForm.red" :min="0" :max="255" show-input></el-slider>
            </el-form-item>
            <el-form-item label="@AR["Auto.UI.5785f658c90c"]" prop="green">
                <el-slider v-model="editForm.green" :min="0" :max="255" show-input></el-slider>
            </el-form-item>
            <el-form-item label="@AR["Auto.UI.1041efcc6d87"]" prop="blue">
                <el-slider v-model="editForm.blue" :min="0" :max="255" show-input></el-slider>
            </el-form-item>
            <el-form-item label="@AR["Auto.UI.d8d8e59e5198"]">
                <div class="color-preview-large" :style="{backgroundColor: `rgb(${editForm.red}, ${editForm.green}, ${editForm.blue})`}">
                    RGB({{editForm.red}}, {{editForm.green}}, {{editForm.blue}})
                </div>
            </el-form-item>
            <el-form-item label="@AR["Auto.UI.133820eee7f5"]" prop="additionNote">
                <el-input v-model="editForm.additionNote" type="textarea" :rows="3" placeholder="@AR["Auto.UI.c26ad5de6440"]"></el-input>
            </el-form-item>
            <el-form-item>
                <el-button @@click="randomizeEditForm" type="info">@AR["Auto.UI.5565d87f760e"]</el-button>
            </el-form-item>
        </el-form>
        <span slot="footer" class="dialog-footer">
            <el-button @@click="editFormDialogVisible = false">@CR["Common.Cancel"]</el-button>
            <el-button type="primary" @@click="editColorSubmit">@CR["Common.Confirm"]</el-button>
        </span>
    </el-dialog>
</div>

@section scripts{
    <script src="~/js/Admin/Template_XncfName/databaseSampleIndex.js"></script>
} 