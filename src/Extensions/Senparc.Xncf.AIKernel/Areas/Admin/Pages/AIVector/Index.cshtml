@page
@model Senparc.Xncf.AIKernel.Areas.AIVector.Pages.Index
@{
    ViewData["Title"] = "AIVector 首页";
    Layout = "_Layout_Vue";
}

@section Style {
    <link href="~/css/Admin/AIVector/index.css" rel="stylesheet" />
}

@section breadcrumbs {
    <el-breadcrumb-item>扩展模块</el-breadcrumb-item>
    <el-breadcrumb-item>AI 核心模块</el-breadcrumb-item>
    <el-breadcrumb-item>首页</el-breadcrumb-item>
}

<div class="aivector-index-page">
    <div class="aivector-main">
        @* 查询区：按向量数据库名称(关键字)查询 *@
        <div class="aivector-query-section">
            <div class="aivector-query-row">
                <label class="aivector-query-label">向量数据库名称</label>
                <el-input v-model="keyword"
                          placeholder="请输入向量数据库名称关键字"
                          size="small"
                          clearable
                          class="aivector-query-input"
                          @@keyup.enter.native="handleSearch()"></el-input>
                <el-button type="primary" size="small" icon="el-icon-search" @@click="handleSearch()">查询</el-button>
                <el-button size="small" icon="el-icon-refresh-left" @@click="resetCondition()">重置</el-button>
            </div>
        </div>

        @* 工具栏 *@
        <div class="aivector-toolbar">
            <el-button type="primary" icon="el-icon-plus" size="small" @@click="addVector">添加</el-button>
        </div>

        @* 表格区域 *@
        <div class="aivector-table-wrap">
    <el-table :data="tableData" v-loading="tableLoading" border size="small">
        @* alias *@
        <el-table-column prop="alias" label="别名" width="auto"></el-table-column>
        <el-table-column prop="name" label="部署名称" width="auto"></el-table-column>
        <el-table-column prop="connectionString" label="Endpoint" width="auto"></el-table-column>
        <el-table-column prop="vectorDBType" label="向量数据库类型" width="auto">
            <template slot-scope="scope">
                <span v-if="scope.row.vectorDBType===0">Memory</span>
                <span v-else-if="scope.row.vectorDBType===1">HardDisk</span>
                <span v-else-if="scope.row.vectorDBType===2">Redis</span>
                <span v-else-if="scope.row.vectorDBType===3">Milvus</span>
                <span v-else-if="scope.row.vectorDBType===4">Chroma</span>
                <span v-else-if="scope.row.vectorDBType===5">PostgreSQL</span>
                <span v-else-if="scope.row.vectorDBType===6">Sqlite</span>
                <span v-else-if="scope.row.vectorDBType===7">SqlServer</span>
                <span v-else-if="scope.row.vectorDBType===8">Qdrant</span>
                @*                 <span v-else-if="scope.row.vectorDBType===9">Milvus</span>
                <span v-else-if="scope.row.vectorDBType===10">MongoDB</span>
                <span v-else-if="scope.row.vectorDBType===11">Pinecon</span>
                <span v-else-if="scope.row.vectorDBType===12">Postgres</span>
                <span v-else-if="scope.row.vectorDBType===13">Qdrant</span>
                <span v-else-if="scope.row.vectorDBType===14">Redis</span>
                <span v-else-if="scope.row.vectorDBType===15">SqlServer</span>
                <span v-else-if="scope.row.vectorDBType===16">SQLite</span>
                <span v-else-if="scope.row.vectorDBType===17">VolatileInMemory</span>
                <span v-else-if="scope.row.vectorDBType===18">Weaviate</span> *@
            </template>
        </el-table-column>
        <el-table-column prop="note" label="备注" width="auto"></el-table-column>
        <el-table-column prop="addTime" label="添加时间" width="auto">
            <template slot-scope="scope">
                {{ dateformatter(scope.row.addTime) }}
            </template>
        </el-table-column>
        @* 操作 *@
        <el-table-column label="操作" align="center" fixed="right" width="160">
            <template slot-scope="scope">
                <el-button type="primary" size="mini" plain @@click="editModel(scope.row)">编辑</el-button>
                <el-button type="danger" size="mini" plain @@click="deleteModel(scope.row)">删除</el-button>
            </template>
        </el-table-column>
    </el-table>
        </div>
        @* 分页：首页、上一页、下一页、尾页、跳转、每页条数 5/10/15/20/50/100，默认 10 *@
        <div class="aivector-pagination-wrap">
            <el-pagination :current-page.sync="page.page"
                           :page-sizes="[5, 10, 15, 20, 50, 100]"
                           :page-size.sync="page.size"
                           :total="total"
                           layout="total, sizes, prev, pager, next, jumper"
                           @@size-change="handleSizeChange"
                           @@current-change="handleCurrentChange">
            </el-pagination>
        </div>
    </div>


    @* dialog for 添加向量数据库 *@
    <el-dialog title="添加向量数据库"
               :visible.sync="addFormDialogVisible"
               width="560px"
               :close-on-click-modal="false"
               custom-class="aivector-form-dialog">
        <el-form :model="addForm"
                 :rules="addRules"
                 ref="addForm"
                 label-position="top"
                 size="small"
                 class="aivector-dialog-form">
            <el-form-item label="别名" prop="alias" class="aivector-form-item">
                <el-input v-model="addForm.alias" placeholder="请输入别名" clearable></el-input>
            </el-form-item>
            <el-form-item label="向量数据库类型" prop="vectorDBType" class="aivector-form-item">
                <el-select v-model="addForm.vectorDBType" placeholder="请选择">
                    <el-option label="Memory" value="0"></el-option>
                    <el-option label="HardDisk" value="1"></el-option>
                    <el-option label="Redis" value="2"></el-option>
                    <el-option label="Milvus" value="3"></el-option>
                    <el-option label="Chroma" value="4"></el-option>
                    <el-option label="PostgreSQL" value="5"></el-option>
                    <el-option label="Sqlite" value="6"></el-option>
                    <el-option label="SqlServer" value="7"></el-option>
                    <el-option label="Qdrant" value="8"></el-option>
                </el-select>
            </el-form-item>
            <el-form-item label="名称" prop="name" class="aivector-form-item">
                <el-input v-model="addForm.name" placeholder="请输入向量数据库名称" clearable></el-input>
            </el-form-item>
            <el-form-item label="连接字符串" prop="connectionString" class="aivector-form-item">
                <el-input v-model="addForm.connectionString" type="textarea" :rows="3" placeholder="请输入连接字符串"></el-input>
            </el-form-item>
            <el-form-item label="备注" prop="note" class="aivector-form-item">
                <el-input v-model="addForm.note" type="textarea" :rows="3" placeholder="请输入备注（选填）"></el-input>
            </el-form-item>
        </el-form>
        <div slot="footer" class="aivector-dialog-footer">
            <el-button @@click="addFormDialogVisible = false">取消</el-button>
            <el-button type="primary" @@click="addModelSubmit">确定</el-button>
        </div>
    </el-dialog>
    @* dialog for 编辑向量数据库 *@
    <el-dialog title="编辑向量数据库"
               :visible.sync="editFormDialogVisible"
               width="560px"
               :close-on-click-modal="false"
               custom-class="aivector-form-dialog">
        <el-form :model="editForm"
                 :rules="editRules"
                 ref="editForm"
                 label-position="top"
                 size="small"
                 class="aivector-dialog-form">
            <el-form-item label="别名" prop="alias" class="aivector-form-item">
                <el-input v-model="editForm.alias" placeholder="请输入别名" clearable></el-input>
            </el-form-item>
            <el-form-item label="向量数据库类型" prop="vectorDBType" class="aivector-form-item">
                <el-select v-model="editForm.vectorDBType" placeholder="请选择">
                    <el-option label="Memory" value="0"></el-option>
                    <el-option label="HardDisk" value="1"></el-option>
                    <el-option label="Redis" value="2"></el-option>
                    <el-option label="Milvus" value="3"></el-option>
                    <el-option label="Chroma" value="4"></el-option>
                    <el-option label="PostgreSQL" value="5"></el-option>
                    <el-option label="Sqlite" value="6"></el-option>
                    <el-option label="SqlServer" value="7"></el-option>
                    <el-option label="Qdrant" value="8"></el-option>
                </el-select>
            </el-form-item>
            <el-form-item label="名称" prop="name" class="aivector-form-item">
                <el-input v-model="editForm.name" placeholder="请输入向量数据库名称" clearable></el-input>
            </el-form-item>
            <el-form-item label="连接字符串" prop="connectionString" class="aivector-form-item">
                <el-input v-model="editForm.connectionString" type="textarea" :rows="3" placeholder="请输入连接字符串"></el-input>
            </el-form-item>
            <el-form-item label="备注" prop="note" class="aivector-form-item">
                <el-input v-model="editForm.note" type="textarea" :rows="3" placeholder="请输入备注（选填）"></el-input>
            </el-form-item>
            <el-form-item label="显示" prop="show" class="aivector-form-item">
                <el-switch v-model="editForm.show"></el-switch>
            </el-form-item>
        </el-form>
        <div slot="footer" class="aivector-dialog-footer">
            <el-button @@click="editFormDialogVisible = false">取消</el-button>
            <el-button type="primary" @@click="editModelSubmit">确定</el-button>
        </div>
    </el-dialog>

</div>

@section scripts {
    <script src="~/js/Admin/AIVector/index.js"></script>
}