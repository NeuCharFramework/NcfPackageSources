                    <div v-for="(item,index) in taskList" :key="index" class="sidebar-agentitem text-ellipsis"
                        :class="{'sidebar-agentitem_active':scrollbarTaskIndex === index}" :title="item.name"
                        @@click="handleTaskView('task',item,index)">
                        {{ item.name }}
                    </div>
                    </template>
                    <div v-else class="df-wn flex-ac flex-jc emptyData"
                        style="flex-grow: 1;font-size: 14px;color: #5e6d82;margin-top:150px;">@AR["AgentsManager.NoData"]</div>
                </el-scrollbar>
            </div>
            @* 主体内容 *@
            <div class="main-container agent-container">
                @* @AR["AgentsManager.AllTasks"] *@
                <template v-if="scrollbarTaskIndex === ''">
                    <div class="df-wn flex-ac flex-js groupInfoRow">
                        <div class="groupInfoRow-name text-ellipsis">
                            @AR["AgentsManager.AllTasks"]
                        </div>
                        <div class="df-wn groupInfoRow-operation">
                            <el-button type="primary" size="mini"
                                @@click="handleTaskStartBatch('taskBatch')">@AR["AgentsManager.BatchStart"]</el-button>
                            <el-button type="danger" size="mini"
                                @@click="handleTaskDeleteBatch('taskBatch')">@AR["AgentsManager.BatchDelete"]</el-button>
                        </div>
                    </div>
                    @* 255 *@
                    <el-table ref="taskList" :data="taskList" key="taskList" :height="`calc(100vh - 300px)`"
                        style="width: 100%;" @@selection-change="handleTaskSelectionChange">
                        <el-table-column type="selection" width="30"></el-table-column>
                        <el-table-column prop="name" label="@AR["AgentsManager.RunTask"]" min-width="170" show-overflow-tooltip>
                            <template slot-scope="{ row }">
                                <i :class="[taskStateIcon[row.status],taskStateColor[row.status]]"></i>
                                <span>{{ row.name }}</span>
                            </template>
                        </el-table-column>
                        <el-table-column label="@AR["AgentsManager.StartTime"]" min-width="100">
                            <template slot-scope="{ row }">
                                {{ row.startTime | showFormatDate }}
                            </template>
                        </el-table-column>
                        <el-table-column label="@AR["AgentsManager.Duration"]" width="100">
                            <template slot-scope="{ row }">
                                {{ calculateDuration(row.startTime,row.endTime) }}
                            </template>
                        </el-table-column>
                        <el-table-column prop="modelName" label="@AR["AgentsManager.ModelName"]" min-width="100" show-overflow-tooltip>
                            <template slot-scope="{ row }">
                                {{ row.modelName }}
                            </template>
                        </el-table-column>
                        <el-table-column prop="promptCommand" label="@AR["AgentsManager.TaskDescription"]" min-width="130" show-overflow-tooltip>
                            <template slot-scope="{ row }">
                                {{ row.promptCommand }}
                            </template>
                        </el-table-column>
                        <el-table-column fixed="right" label="@CR["Common.Action"]" width="350">
                            <template slot-scope="{ row,$index }">
                                <el-button type="primary" size="mini"
                                    @@click="viewAgentParameters('task', row)">@AR["AgentsManager.AgentParameters"]</el-button>
                                <el-button type="primary" size="mini"
                                    @@click="handleTaskView('task', row, $index)">@AR["AgentsManager.Details"]</el-button>
                                <el-button type="primary" size="mini"
                                    @@click="handleTaskAgain('task', row)">@AR["AgentsManager.RunAgain"]</el-button>
                                <el-button type="danger" size="mini"
                                    @@click="handleTaskDelet('task', row)">@CR["Common.Delete"]</el-button>
                            </template>
                        </el-table-column>
                    </el-table>
                </template>
                <template v-else-if="taskDetails">
                    <div class="df-wn flex-ac flex-js task-header">
                        <div class="task-header_left">
                            <div class="task-header1 text-ellipsis" :title="taskDetails.name">
                                {{ taskDetails.name }}
                            </div>
                            <div class="task-header2" style="flex-shrink: 0;">
                                <i :class="[taskStateIcon[taskDetails.status],taskStateColor[taskDetails.status]]"></i>
                                {{ taskStateText[taskDetails.status] }}
                            </div>
                        </div>
                        @* type="text" *@
                        <div class="task-header_right">
                            <el-button type="primary" size="mini"
                                @@click="viewAgentParameters('taskDetail')">@AR["AgentsManager.AgentParameters"]</el-button>
                            <el-button type="primary" size="mini"
                                @@click="handleTaskAgain('task',taskDetails)">@AR["AgentsManager.RunAgain"]</el-button>
                        </div>
                    </div>
                    <div class="df flex-ac flex-jc task-info">
                        <div class="itembox">
                            <div class="lable">@AR["AgentsManager.TaskStartTime"]:</div>
                            <div class="value">{{ taskDetails.startTime |
                                showFormatDate }}
                            </div>
                        </div>
                        <div class="itembox">
                            <div class="lable">@AR["AgentsManager.Model"]:</div>
                            <div class="value">{{ taskDetails.modelName }}</div>
                        </div>
                        <div class="itembox">
                            <div class="lable">@AR["AgentsManager.TaskDescription"]:</div>
                            <div class="value">
                                <span class="text-ellipsis">{{ taskDetails.promptCommand }}</span>
                                @* 详情 type="primary" *@
                                <el-button type="text" size="mini"
                                    @@click="viewTaskDescription(taskDetails)">@AR["AgentsManager.Details"]</el-button>
                            </div>
                        </div>
                        <div class="itembox">
                            <div class="lable">@AR["AgentsManager.TaskEndTime"]:</div>
                            <div class="value">{{ taskDetails.endTime |
                                showFormatDate }}</div>
                        </div>
                        <div class="itembox">
                            <div class="lable">@AR["AgentsManager.Scoring"]:</div>
                            <div class="value">{{ taskDetails.score }}</div>
                        </div>
                        <div class="itembox">
                            <div class="lable">@AR["AgentsManager.TaskEvaluation"]:</div>
                            <div class="value">
                                @* 编辑 type="primary" *@
                                <el-button type="text" size="mini" @@click="taskEvaluation(taskDetails)">@CR["Common.Edit"]</el-button>
                            </div>
                        </div>
                    </div>
                    <div class="df-wn task-main">
                        <div class="taskmain-record">
                            <el-scrollbar ref="taskHistoryScrollbar" class="sidebar-taskrecord-container"
                                wrap-class="scrollbar-wrapper">
                                <div class="df-wn flex-dc taskrecord-listWrap">
                                    <div v-for="ritem in taskHistoryList" :key="ritem.id" v-show="!taskMemberfilter || taskMemberfilterList.includes(ritem.fromAgentTemplateId)"
                                        class="taskrecord-listWrap-item">
                                        <div class="taskrecord-listWrap-item-head">
                                            <span class="df-wn flex-ac flex-jc avatarBox">
                                                <img :src="getTaskSenderInfo('task',ritem.fromAgentTemplateId).avastar | showAvatar"
                                                    alt="">
                                            </span>
                                            <span class="name">{{
                                                getTaskSenderInfo('task',ritem.fromAgentTemplateId).name }}</span>
                                            <span class="time">{{ ritem.addTime | showFormatDate }}</span>
                                        </div>
                                        <task-html-renderer :content="ritem.messageHtml" />
                                    </div>
                                </div>
                            </el-scrollbar>
                        </div>
                        <div class="taskmain-members">
                            <el-input v-model="taskMemberfilter" placeholder="@AR["AgentsManager.SearchByNamePlaceholder"]" suffix-icon="el-icon-search" style="margin-bottom: 15px;" @@input="handleTaskFilterChange($event,'task')"></el-input>
                            <div class="taskmain-members-title">
                                @AR["AgentsManager.RobotCount"] ·{{ taskMemberList ? taskMemberList.length : 0 }}
                            </div>
                            <el-scrollbar class="sidebar-taskmembers-container" wrap-class="scrollbar-wrapper">
                                <div class="df-wn flex-dc taskmain-members-listWrap">
                                    <div v-for="mitem in taskMemberList" :key="mitem.id" v-show="mitem.name.includes(taskMemberfilter)"
                                        class="taskmain-members-listWrap-item">
                                        <div class="df-wn flex-ac flex-jc avatarBox">
                                            <img :src="mitem.avastar | showAvatar" alt="">
                                        </div>
                                        <span class="name text-ellipsis">{{ mitem.name }}</span>
                                    </div>
                                </div>
                            </el-scrollbar>
                        </div>
                    </div>
                </template>
                <div v-else class="df-wn flex-ac flex-jc emptyData"
                    style="flex-grow: 1;font-size: 14px;color: #5e6d82;margin-top:150px;">@AR["AgentsManager.NoData"]</div>
            </div>
        </div>
    </el-tab-pane>
</el-tabs>

@* 抽屉 新增|编辑 智能体 540px *@
<el-drawer :visible.sync="visible.drawerAgent" direction="rtl" :with-header="false" :wrapper-closable="false"
    :close-on-press-escape="false" size="960px">
    <div class="drawerRtl">
        @* 内容中的头（包括标题和关闭图标） *@
        <div class="drawerRtl__header">
            <div class="drawerRtl__header__title">{{ agentForm.id ? '@AR["AgentsManager.EditAgent"]' : '@AR["AgentsManager.AddAgent"]' }}</div>
            <div class="drawerRtl__header__close" @@click="handleElVisibleClose('drawerAgent')">&times;</div>
        </div>
        @* 内容中的主体内容 *@
        <div class="drawerRtl__body">
            <el-form v-if="visible.drawerAgent" ref="agentELForm" :model="agentForm" :rules="agentFormRules"
                :size="elSize" label-position="left" label-width="130px" class="drawerForm-container">
                <el-form-item label="@AR["AgentsManager.AgentName"]" prop="name">
                    <el-input v-model="agentForm.name" placeholder="@AR["AgentsManager.PleaseFill"]"></el-input>
                </el-form-item>
                <el-form-item label="SystemMessage" required>
                    <el-radio-group v-model="agentForm.systemMessageType">
                        <el-radio label="1" border>@AR["AgentsManager.SelfSelect"]</el-radio>
                        <el-radio label="2" border>@AR["AgentsManager.Manual"]</el-radio>
                    </el-radio-group>
                </el-form-item>
                <el-form-item v-if="agentForm.systemMessageType === '1'" label="@AR["AgentsManager.SelfSelect"]" prop="systemMessage">
                    @* @change="handleChange($event,'')" *@
                    <load-more-select v-model="agentForm.systemMessage" service-type="systemMessage"
                        direction="vertical" placeholder="@AR["AgentsManager.PleaseSelect"]" />
                </el-form-item>
                <el-form-item v-if="agentForm.systemMessageType === '2'" label="@AR["AgentsManager.ManualInput"]" prop="systemMessage">
                    <el-input  
                       type="textarea"  
                       v-model="agentForm.systemMessage"  
                       @@change="handleIdentify"  
                       placeholder="@AR["AgentsManager.PleaseFill"]"  
                       :rows="4">  
                    </el-input>
                    
                </el-form-item>
                <el-form-item label="@AR["AgentsManager.EnableSwitch"]" prop="enable">
                    <el-checkbox v-model="agentForm.enable">@AR["AgentsManager.EnableAgent"]</el-checkbox>
                </el-form-item>
                <el-form-item label="@AR["AgentsManager.ExternalPlatform"]" prop="hookRobotType">
                    <el-select v-model="agentForm.hookRobotType" style="width:100%" placeholder="@AR["AgentsManager.PleaseSelect"]">
                        <el-option label="None" :value="0"></el-option>
                        <el-option label="WeChatMp" :value="1"></el-option>
                        <el-option label="WeChatWorkRobot" :value="2"></el-option>
                    </el-select>
                </el-form-item>
                <el-form-item label="@AR["AgentsManager.ExternalPlatformParameters"]" prop="hookRobotParameter">
                    <el-input v-model="agentForm.hookRobotParameter" placeholder="@AR["AgentsManager.PleaseFill"]" :disabled="agentForm.hookRobotType === 0"></el-input>
                </el-form-item>
                <el-form-item label="@AR["AgentsManager.AgentAvatar"]" prop="avastar">
                    <div class="df-wn flex-ac flex-js agentForm-agentAvatarBox">
                        <div v-for="(aitem,aindex) in agentAvatarList" :key="aindex"
                            class="df-wn flex-ac flex-jc agentAvatarBoxItem"
                            :class="{'agentAvatarBoxItem-active':aitem === agentForm.avastar}"
                            @@click="handleFormValidateField('agentELForm','agentForm','avastar',aitem)">
                            <img :src="aitem" alt="">
                        </div>
                    </div>
                </el-form-item>
                <el-form-item label="Function Calls" prop="functionCallNames">
                    <div class="function-call-container">
                        <div class="function-call-tags">
                            <el-tag
                                v-for="tag in agentForm.functionCallNames ? agentForm.functionCallNames.split(',').filter(x => x) : []"
                                :key="tag"
                                closable
                                :disable-transitions="false"
                                @@close="handleFunctionCallClose(tag)"
                                class="function-call-tag">
                                {{tag}}
                            </el-tag>
                            <el-input
                                v-if="functionCallInputVisible"
                                ref="functionCallInput"
                                v-model="functionCallInputValue"
                                class="input-new-tag"
                                size="small"
                                placeholder="@AR["AgentsManager.PluginClassPlaceholder"]"
                                @@keyup.enter.native="handleFunctionCallInputConfirm"
                                @@blur="handleFunctionCallInputConfirm">
                            </el-input>
                            <el-button v-else class="button-new-tag" size="small" @@click="showFunctionCallInput">+ @AR["AgentsManager.Add"]</el-button>
                        </div>
                        
                        <div class="plugin-types-container" v-if="availablePluginTypes.length">
                            <div class="plugin-types-title">@AR["AgentsManager.AvailablePluginTypes"]</div>
                            <div class="plugin-types-list">
                                <el-button
                                    v-for="pluginType in availablePluginTypes"
                                    :key="pluginType"
                                    size="small"
                                    type="info"
                                    plain
                                    class="plugin-type-btn"
                                    @@click="handleAddPluginType(pluginType)">
                                    {{ pluginType }}
                                </el-button>
                            </div>
                        </div>
                    </div>
                </el-form-item>
                
                <el-form-item label="MCP Endpoints" prop="mcpEndpoints">
                    <div class="mcp-endpoints-container">
                        <div class="mcp-endpoints-list">
                            <div v-for="(endpoint, name) in parsedMcpEndpoints" :key="name" class="mcp-endpoint-item">
                                <div class="mcp-endpoint-info">
                                    <span class="mcp-endpoint-name">{{name}}</span>
                                    <span class="mcp-endpoint-url">{{endpoint.url}}</span>
                                    <div v-if="endpoint.testResult && endpoint.testResult.success" class="mcp-endpoint-test-result">
                                        <div class="test-status success">@AR["AgentsManager.ConnectionSuccess"]</div>
                                        <el-button size="mini" type="primary" plain @@click="showMcpToolsDialog(endpoint)">
                                            @AR["AgentsManager.ViewToolList"] ({{endpoint.testResult.tools ? endpoint.testResult.tools.length : 0}})
                                        </el-button>
                                    </div>
                                    <div v-else-if="endpoint.testResult && !endpoint.testResult.success" class="mcp-endpoint-test-result">
                                        <div class="test-status failed">@AR["AgentsManager.ConnectionFailed"]: {{endpoint.testResult.message}}</div>
                                    </div>
                                </div>
                                <div class="mcp-endpoint-actions">
                                    <el-button 
                                        size="mini" 
                                        type="success" 
                                        icon="el-icon-connection" 
                                        circle 
                                        @@click="testMcpEndpoint(name, endpoint)"
                                        :loading="endpoint.testing"
                                        style="margin-right: 5px;"
                                        title="@AR["AgentsManager.TestConnection"]">
                                    </el-button>
                                    <el-button 
                                        size="mini" 
                                        type="primary" 
                                        icon="el-icon-edit" 
                                        circle 
                                        @@click="handleMcpEndpointEdit(name, endpoint)"
                                        style="margin-right: 5px;">
                                    </el-button>
                                    <el-button 
                                        size="mini" 
                                        type="danger" 
                                        icon="el-icon-delete" 
                                        circle 
                                        @@click="handleMcpEndpointRemove(name)">
                                    </el-button>
                                </div>
                            </div>
                        </div>
                        
                        <div class="mcp-endpoint-add" v-if="!mcpEndpointInputVisible">
                            <el-button class="button-new-endpoint" size="small" @@click="showMcpEndpointInput">+ @AR["AgentsManager.AddMcpEndpoint"]</el-button>
                        </div>
                        
                        <div v-if="mcpEndpointInputVisible" class="mcp-endpoint-input-form">
                            <div class="mcp-endpoint-form-title">{{ mcpEndpointEditMode ? '@AR["AgentsManager.EditMcpEndpoint"]' : '@AR["AgentsManager.AddMcpEndpoint"]' }}</div>
                            <el-input
                                ref="mcpEndpointNameInput"
                                v-model="mcpEndpointNameValue"
                                class="input-endpoint-name"
                                size="small"
                                placeholder="@AR["AgentsManager.EndpointNamePlaceholder"]"
                                style="margin-bottom: 10px; width: 100%">
                            </el-input>
                            
                            <el-input
                                ref="mcpEndpointUrlInput"
                                v-model="mcpEndpointUrlValue"
                                class="input-endpoint-url"
                                size="small"
                                placeholder="@AR["AgentsManager.EndpointUrlPlaceholder"]"
                                style="margin-bottom: 10px; width: 100%">
                            </el-input>
                            
                            <div class="endpoint-input-actions">
                                <el-button size="small" type="primary" @@click="handleMcpEndpointInputConfirm">@CR["Common.Confirm"]</el-button>
                                <el-button size="small" @@click="cancelMcpEndpointInput">@CR["Common.Cancel"]</el-button>
                            </div>
                        </div>
                    </div>
                </el-form-item>
                
                <el-form-item label="@CR["Common.Remark"]" prop="description">
                    <el-input type="textarea" v-model="agentForm.description" :rows="4" placeholder="@AR["AgentsManager.FillAdminOnly"]"></el-input>
                </el-form-item>
            </el-form>
        </div>
        @* 内容中固定的footer *@
        <div class="drawerRtl__footer text-right">
            <el-button :size="elSize" @@click="handleElVisibleClose('drawerAgent')">@CR["Common.Cancel"]</el-button>
            <el-button :size="elSize" type="primary" @@click="handleElVisibleSubmit('drawerAgent')">@CR["Common.Confirm"]</el-button>
        </div>
    </div>
</el-drawer>
