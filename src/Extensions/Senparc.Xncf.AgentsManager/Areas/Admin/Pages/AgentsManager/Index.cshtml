                <el-form-item label="@AR["AgentsManager.SelectGroup"]" prop="groupName">
                    <el-input v-model="groupStartForm.groupName" disabled placeholder="@AR["AgentsManager.PleaseFill"]"></el-input>
                </el-form-item>
                <el-form-item label="@AR["AgentsManager.TaskTitle"]" prop="name">
                    <el-input v-model="groupStartForm.name" placeholder="@AR["AgentsManager.PleaseFill"]"></el-input>
                </el-form-item>
                <el-form-item label="@AR["AgentsManager.SelectModel"]" prop="aiModelId">
                    @* @change="handleChange($event,'')" *@
                    <load-more-select v-model="groupStartForm.aiModelId" service-type="model" direction="vertical"
                        placeholder="@AR["AgentsManager.PleaseSelect"]" />
                </el-form-item>
                <el-form-item label="@AR["AgentsManager.PersonalizedAgent"]" prop="personality">
                    <el-checkbox v-model="groupStartForm.personality">@AR["AgentsManager.RunWithPersonalizedParameters"]</el-checkbox>
                </el-form-item>
                <el-form-item label="@AR["AgentsManager.TaskDescription"]" prop="promptCommand">
                    <el-input type="textarea" v-model="groupStartForm.promptCommand" :rows="8"
                        placeholder="@AR["AgentsManager.WhatCanIDoForYou"]"></el-input>
                </el-form-item>
                <el-form-item label="@CR["Common.Description"]" prop="description">
                    <el-input type="textarea" v-model="groupStartForm.description" :rows="8"
                        placeholder="@AR["AgentsManager.PleaseFill"]"></el-input>
                </el-form-item>
            </el-form>
        </div>
        @* 内容中固定的footer *@
        <div class="drawerRtl__footer text-right">
            <el-button :size="elSize" @@click="handleElVisibleClose('drawerGroupStart')">@CR["Common.Cancel"]</el-button>
            <el-button :size="elSize" type="primary" @@click="handleElVisibleSubmit('drawerGroupStart')">@CR["Common.Confirm"]</el-button>
        </div>
    </div>
</el-drawer>
@* Dialog 智能体 新增 *@
<el-dialog :title="agentForm.id ? '@AR["AgentsManager.EditAgent"]' : '@AR["AgentsManager.AddAgent"]'" :visible.sync="visible.dialogGroupAgent" :show-close="false"
    :close-on-click-modal="false" :close-on-press-escape="false">
    <el-form v-if="visible.dialogGroupAgent" ref="agentELForm" :model="agentForm" :rules="agentFormRules" :size="elSize"
        label-position="left" label-width="130px" class="drawerForm-container">
        <el-form-item label="@AR["AgentsManager.AgentName"]" prop="name">
            <el-input v-model="agentForm.name" placeholder="@AR["AgentsManager.PleaseFill"]"></el-input>
        </el-form-item>
        <el-form-item label="SystemMessage" required>
            <el-radio-group v-model="agentForm.systemMessageType">
                <el-radio label="1" border>@AR["AgentsManager.SelfSelect"]</el-radio>
                <el-radio label="2" border>@AR["AgentsManager.Manual"]</el-radio>
            </el-radio-group>
        </el-form-item>
        <el-form-item v-if="agentForm.systemMessageType === '1'" label="@AR["AgentsManager.SelfSelect"]" prop="systemMessage">
            <load-more-select v-model="agentForm.systemMessage" service-type="systemMessage" direction="vertical"
                placeholder="@AR["AgentsManager.PleaseSelect"]" />
        </el-form-item>
        <el-form-item v-if="agentForm.systemMessageType === '2'" label="@AR["AgentsManager.ManualInput"]" prop="systemMessage">
            <el-input v-model="agentForm.systemMessage" placeholder="@AR["AgentsManager.PleaseFill"]"></el-input>
        </el-form-item>
        <el-form-item label="@AR["AgentsManager.EnableSwitch"]" prop="enable">
            <el-checkbox v-model="agentForm.enable">@AR["AgentsManager.EnableAgent"]</el-checkbox>
        </el-form-item>
        <el-form-item label="@CR["Common.Description"]" prop="description">
            <el-input type="textarea" v-model="agentForm.description" :rows="4" placeholder="@AR["AgentsManager.PleaseFill"]"></el-input>
        </el-form-item>
        <el-form-item label="@AR["AgentsManager.ExternalPlatform"]" prop="hookRobotType">
            <el-select v-model="agentForm.hookRobotType" style="width:100%" placeholder="@AR["AgentsManager.PleaseSelect"]">
                <el-option label="None" :value="0"></el-option>
                <el-option label="WeChatMp" :value="1"></el-option>
                <el-option label="WeChatWorkRobot" :value="2"></el-option>
            </el-select>
        </el-form-item>
        <el-form-item label="@AR["AgentsManager.ExternalPlatformParameters"]" prop="hookRobotParameter">
            <el-input v-model="agentForm.hookRobotParameter" placeholder="@AR["AgentsManager.PleaseFill"]" :disabled="agentForm.hookRobotType === 0"></el-input>
        </el-form-item>
        <el-form-item label="@AR["AgentsManager.AgentAvatar"]" prop="avastar">
            <div class="df-wn flex-ac flex-js agentForm-agentAvatarBox">
                <div v-for="(aitem,aindex) in agentAvatarList" :key="aindex"
                    class="df-wn flex-ac flex-jc agentAvatarBoxItem"
                    :class="{'agentAvatarBoxItem-active':aitem === agentForm.avastar}"
                    @@click="handleFormValidateField('agentELForm','agentForm','avastar',aitem)">
                    <img :src="aitem" alt="">
                </div>
            </div>
        </el-form-item>
        <el-form-item label="Function Calls" prop="functionCallNames">
            <div class="function-call-container">
                <div class="function-call-tags">
                    <el-tag
                        v-for="tag in agentForm.functionCallNames ? agentForm.functionCallNames.split(',').filter(x => x) : []"
                        :key="tag"
                        closable
                        :disable-transitions="false"
                        @@close="handleFunctionCallClose(tag)"
                        class="function-call-tag">
                        {{tag}}
                    </el-tag>
                    <el-input
                        v-if="functionCallInputVisible"
                        ref="functionCallInput"
                        v-model="functionCallInputValue"
                        class="input-new-tag"
                        size="small"
                        placeholder="@AR["AgentsManager.PluginClassPlaceholder"]"
                        @@keyup.enter.native="handleFunctionCallInputConfirm"
                        @@blur="handleFunctionCallInputConfirm">
                    </el-input>
                    <el-button v-else class="button-new-tag" size="small" @@click="showFunctionCallInput">+ @AR["AgentsManager.Add"]</el-button>
                </div>
                
                <div class="plugin-types-container" v-if="availablePluginTypes.length">
                    <div class="plugin-types-title">@AR["AgentsManager.AvailablePluginTypes"]</div>
                    <div class="plugin-types-list">
                        <el-button
                            v-for="pluginType in availablePluginTypes"
                            :key="pluginType"
                            size="small"
                            type="info"
                            plain
                            class="plugin-type-btn"
                            @@click="handleAddPluginType(pluginType)">
                            {{ pluginType }}
                        </el-button>
                    </div>
                </div>
            </div>
        </el-form-item>
        
        <el-form-item label="MCP Endpoints" prop="mcpEndpoints">
            <div class="mcp-endpoints-container">
                <div class="mcp-endpoints-list">
                    <div v-for="(endpoint, name) in parsedMcpEndpoints" :key="name" class="mcp-endpoint-item">
                        <div class="mcp-endpoint-info">
                            <span class="mcp-endpoint-name">{{name}}</span>
                            <span class="mcp-endpoint-url">{{endpoint.url}}</span>
                            <div v-if="endpoint.testResult && endpoint.testResult.success" class="mcp-endpoint-test-result">
                                <div class="test-status success">@AR["AgentsManager.ConnectionSuccess"]</div>
                                <el-button size="mini" type="primary" plain @@click="showMcpToolsDialog(endpoint)">
                                    @AR["AgentsManager.ViewToolList"] ({{endpoint.testResult.tools ? endpoint.testResult.tools.length : 0}})
                                </el-button>
                            </div>
                            <div v-else-if="endpoint.testResult && !endpoint.testResult.success" class="mcp-endpoint-test-result">
                                <div class="test-status failed">@AR["AgentsManager.ConnectionFailed"]: {{endpoint.testResult.message}}</div>
                            </div>
                        </div>
                        <div class="mcp-endpoint-actions">
                            <el-button 
                                size="mini" 
                                type="success" 
                                icon="el-icon-connection" 
                                circle 
                                @@click="testMcpEndpoint(name, endpoint)"
                                :loading="endpoint.testing"
                                style="margin-right: 5px;"
                                title="@AR["AgentsManager.TestConnection"]">
                            </el-button>
                            <el-button 
                                size="mini" 
                                type="primary" 
                                icon="el-icon-edit" 
                                circle 
                                @@click="handleMcpEndpointEdit(name, endpoint)"
                                style="margin-right: 5px;">
                            </el-button>
                            <el-button 
                                size="mini" 
                                type="danger" 
                                icon="el-icon-delete" 
                                circle 
                                @@click="handleMcpEndpointRemove(name)">
                            </el-button>
                        </div>
                    </div>
                </div>
                
                <div class="mcp-endpoint-add" v-if="!mcpEndpointInputVisible">
                    <el-button class="button-new-endpoint" size="small" @@click="showMcpEndpointInput">+ @AR["AgentsManager.AddMcpEndpoint"]</el-button>
                </div>
                
                <div v-if="mcpEndpointInputVisible" class="mcp-endpoint-input-form">
                    <div class="mcp-endpoint-form-title">{{ mcpEndpointEditMode ? '@AR["AgentsManager.EditMcpEndpoint"]' : '@AR["AgentsManager.AddMcpEndpoint"]' }}</div>
                    <el-input
                        ref="mcpEndpointNameInput"
                        v-model="mcpEndpointNameValue"
                        class="input-endpoint-name"
                        size="small"
                        placeholder="@AR["AgentsManager.EndpointNamePlaceholder"]"
                        style="margin-bottom: 10px; width: 100%">
                    </el-input>
                    
                    <el-input
                        ref="mcpEndpointUrlInput"
                        v-model="mcpEndpointUrlValue"
                        class="input-endpoint-url"
                        size="small"
                        placeholder="@AR["AgentsManager.EndpointUrlPlaceholder"]"
                        style="margin-bottom: 10px; width: 100%">
                    </el-input>
                    
                    <div class="endpoint-input-actions">
                        <el-button size="small" type="primary" @@click="handleMcpEndpointInputConfirm">@CR["Common.Confirm"]</el-button>
                        <el-button size="small" @@click="cancelMcpEndpointInput">@CR["Common.Cancel"]</el-button>
                    </div>
                </div>
            </div>
        </el-form-item>
    </el-form>
    <div slot="footer" class="dialog-footer">
        <el-button @@click="handleElVisibleClose('dialogGroupAgent')">@CR["Common.Cancel"]</el-button>
        <el-button type="primary" @@click="handleElVisibleSubmit('dialogGroupAgent')">@CR["Common.Confirm"]</el-button>
    </div>
</el-dialog>
@* Dialog Carousel 智能体 参数列表 *@
<el-dialog title="@AR["AgentsManager.AgentParameters"]" :visible.sync="visible.dialogAgentParameter" :show-close="false" :close-on-click-modal="false"
    :close-on-press-escape="false" width="80%">
    <div class="dialog-agentParameters">
        <el-tabs v-model="agentParameterTabsValue">
            <el-tab-pane v-for="(item, index) in agentParameterList" :key="item.name" :label="item.name" :name="index">
                <div class="df-wn flex-as flex-jsb agentParameters-head">
                        <div class="df-wn flex-ac flex-js headavatar">
                            <div class="df-wn flex-ac flex-jc avatarBox">
                                <img :src="item.avastar | showAvatar" alt="">
                            </div>
                            <div class="namebox">
                                <div class="name text-ellipsis">
                                    {{ item.name }}
                                </div>
                                <div class="description text-ellipsis-3line">
                                    {{ item.description }}
                                </div>
                            </div>
                        </div>
                        <div class="df-wn flex-dc flex-jsb headitem">
                            <div class="df-wn flex-ac flex-js itemBox">
                                <span class="label">@AR["AgentsManager.AimRange"]:</span>
                                <span class="value">
                                    {{ handlePromptShowName('1',item) }}
                                </span>
                            </div>
                            <div class="df-wn flex-ac flex-js itemBox">
                                <span class="label">@AR["AgentsManager.AimTrack"]:</span>
                                <span class="value">
                                    {{ handlePromptShowName('2',item) }}
                                </span>
                            </div>
                            <div class="df-wn flex-ac flex-js itemBox">
                                <span class="label">@AR["AgentsManager.Model"]:</span>
                                <span class="value">{{ item.aiModelDto ? item.aiModelDto.deploymentName : '' }}</span>
                            </div>
                        </div>
                        <div class="df-wn flex-dc flex-jsb headitem">
                            <div class="df-wn flex-ac flex-js itemBox">
                                <span class="label">Top_p:</span>
                                <span class="value">{{ item.promptItemDto ?item.promptItemDto.topP : '' }} </span>
                            </div>
                            <div class="df-wn flex-ac flex-js itemBox">
                                <span class="label">MaxToken:</span>
                                <span class="value">{{ item.promptItemDto ?item.promptItemDto.maxToken : '' }} </span>
                            </div>
                            <div class="df-wn flex-ac flex-js itemBox">
                                <span class="label">Presence_penalty:</span>
                                <span class="value">{{ item.promptItemDto ?item.promptItemDto.presencePenalty : '' }} </span>
                            </div>
                        </div>
                        <div class="df-wn flex-dc flex-jsb headitem">
                            <div class="df-wn flex-ac flex-js itemBox">
                                <span class="label">Temperature:</span>
                                <span class="value">{{ item.promptItemDto ?item.promptItemDto.temperature : '' }} </span>
                            </div>
                            <div class="df-wn flex-ac flex-js itemBox">
                                <span class="label">Frequeny_penalty:</span>
                                <span class="value">{{ item.promptItemDto ?item.promptItemDto.frequencyPenalty : '' }} </span>
                            </div>
                            <div class="df-wn flex-ac flex-js itemBox">
                                <span class="label">StopSequences:</span>
                                <span class="value">{{ item.promptItemDto ?item.promptItemDto.stopSequences : '' }} </span>
                            </div>
                        </div>
                </div>
                <div class="df-wn flex-as agentParameters-main">
                    <div class="promptContent">
                        <div class="prompt-title">
                            Prompt
                        </div>
                        <div class="prompt-value">

                        </div>
                    </div>
                    <div class="promptResult">
                        <div class="prompt-title">
                            <div>
                                <img src="~/images/AgentsManager/prompt_selectPrompt.svg" alt="" style="width: 15px;height:15px;" />
                                <span class="label">@AR["AgentsManager.AimRange"]:</span>
                                <span class="value">202401.15.1</span>
                            </div>
                            <div>
                                <span class="label">@AR["AgentsManager.AimTrack"]:</span>
                                <span class="value">T2.3</span>
                            </div>
                            <div>
                                <span class="label">@AR["AgentsManager.Aiming"]:</span>
                                <span class="value">A1</span>
                            </div>
                            <div>
                                <span class="label">@AR["AgentsManager.AverageScore"]:</span>
                                <span class="value">10</span>
                            </div>
                            <div>
                                <span class="label">@AR["AgentsManager.HighestScore"]:</span>
                                <span class="value">10</span>
                            </div>
                        </div>
                        <div class="prompt-value">
                            @* <i class="far fa-bullseye-arrow" ></i> *@
                            <div v-for="(oitem,oindex) in item.outputList" :key="oitem.id" class="contentBoxItem">
                    <div class="promptResult_Item_Title">
                        <div class="promptReultTimeArea">
                            <span>{{oitem.addTime}} [@AR["AgentsManager.CostTimeMs"]:{{oitem.costTime}}]</span>
                        </div>
                        <div class="copyButtonArea">
                            <a href="javascript:void(0);" @@click="copyText('2',oitem)" title="@AR["AgentsManager.CopyFormattedHtml"]"><i class="fa fa-copy"></i> HTML</a>
                            <a href="javascript:void(0);" @@click="copyText('1',oitem)" title="@AR["AgentsManager.CopyRawContent"]"><i class="fa fa-copy"></i> @AR["AgentsManager.Raw"]</a>
                        </div>
                    </div>
                    <task-html-renderer class="contentRow" :content="oitem.resultStringHtml" />
                </div>
                        </div>
                    </div>
                </div>
            </el-tab-pane>
        </el-tabs>
    </div>
    <div slot="footer" class="dialog-footer">
        <el-button type="primary" @@click="handleElVisibleClose('dialogAgentParameter')">@CR["Common.Close"]</el-button>
    </div>
</el-dialog>
@* Dialog @AR["AgentsManager.TaskDescription"] *@
<el-dialog title="@AR["AgentsManager.TaskDescription"]" :visible.sync="visible.dialogTaskDescription" :show-close="false" :close-on-click-modal="false"
    :close-on-press-escape="false">
    <div class="dialog-describeContent">
        {{ describeContent }}
    </div>
    <div slot="footer" class="dialog-footer">
        <el-button type="text" @@click="taskDescriptionCopy">
            <i class="far fa-clone"></i>
            @AR["AgentsManager.OneClickCopy"]
        </el-button>
        <el-button @@click="handleElVisibleClose('dialogTaskDescription')">@CR["Common.Close"]</el-button>
    </div>
</el-dialog>
@* Dialog 任务评价 *@
<el-dialog title="@AR["AgentsManager.TaskEvaluation"]" :visible.sync="visible.dialogTaskEvaluation" :show-close="false" :close-on-click-modal="false"
    :close-on-press-escape="false">
    <el-form v-if="visible.dialogTaskEvaluation" ref="evaluationELForm" :model="evaluationForm"
        :rules="evaluationFormRules" :size="elSize" label-position="top" label-width="130px"
        class="drawerForm-container">
        <el-form-item label="@AR["AgentsManager.PleaseEnterScore"]" prop="score">
            @* <el-input v-model="evaluationForm.score" placeholder="@AR["AgentsManager.PleaseFill"]"
            @@input="handleInputNum($event,'evaluationForm.score')"></el-input> *@
            <el-slider v-model="evaluationForm.score" min="0" max="10" step="0.1"></el-slider>
        </el-form-item>
        <el-form-item label="@AR["AgentsManager.PleaseEnterEvaluation"]" prop="evaluation">
            <el-input type="textarea" v-model="evaluationForm.evaluation" :rows="4" placeholder="@AR["AgentsManager.PleaseFill"]"></el-input>
        </el-form-item>
    </el-form>
    <div slot="footer" class="dialog-footer">
        <el-button type="primary" @@click="handleElVisibleSubmit('dialogTaskEvaluation')">@CR["Common.Confirm"]</el-button>
        <el-button @@click="handleElVisibleClose('dialogTaskEvaluation')">@CR["Common.Cancel"]</el-button>
    </div>
</el-dialog>
@* Dialog MCP工具列表 *@
<el-dialog title="@AR["AgentsManager.McpToolsList"]" :visible.sync="visible.dialogMcpTools" :append-to-body="true" width="80%" :show-close="true" :destroy-on-close="false" center>
    <div v-if="currentMcpTools && currentMcpTools.length > 0">
        <el-table :data="currentMcpTools" style="width: 100%">
            <el-table-column prop="name" label="@AR["AgentsManager.ToolName"]" width="180"></el-table-column>
            <el-table-column prop="description" label="@CR["Common.Description"]"></el-table-column>
            <el-table-column label="@AR["AgentsManager.Parameters"]" width="300">
                <template slot-scope="scope">
                    <div v-if="scope.row.parameters && scope.row.parameters.length > 0">
                        <div v-for="param in scope.row.parameters" :key="param.name" class="param-item-table">
                            <strong>{{param.name}}</strong>: {{param.description}}
                        </div>
                    </div>
                    <span v-else>@AR["AgentsManager.NoParameters"]</span>
                </template>
            </el-table-column>
        </el-table>
    </div>
    <div v-else class="empty-tools">
        <div class="empty-text">@AR["AgentsManager.NoAvailableTools"]</div>
    </div>
    <div class="dialog-footer" slot="footer">
        <el-button type="primary" @@click="visible.dialogMcpTools = false">@CR["Common.Close"]</el-button>
    </div>
</el-dialog>
@section scripts {
    <script src="~/js/AgentsManager/lib/axios.min.js"></script>
    <script src="~/js/PromptRange/lib/marked.min.js"></script>
    <script src="~/js/AgentsManager/axios.js"></script>
    <script src="~/js/AgentsManager/index.js"></script>
}
