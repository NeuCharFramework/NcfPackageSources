@page
@model Senparc.Xncf.WeixinManager.Areas.Admin.WeixinManager.WeixinUser_IndexModel
@inject Microsoft.Extensions.Localization.IStringLocalizerFactory LocalizerFactory
@{
    //var namePrefix = Model.MpAccountDto != null ? $"{Model.MpAccountDto.Name
    var AR = LocalizerFactory.Create("Senparc.Areas.Admin.Resources.AdminResource", "Senparc.Areas.Admin");
    var CR = LocalizerFactory.Create("Senparc.Ncf.XncfBase.Resources.CommonResource", "Senparc.Ncf.XncfBase");
}的" : "所有";
    //ViewData["Title"] = $"{namePrefix}用户";
    Layout = "_Layout_Vue";
}
@section breadcrumbs {
    <el-breadcrumb-item>@CR["Common.ExtensionModules"]</el-breadcrumb-item>
    <el-breadcrumb-item>@CR["Common.ModuleManagement"]</el-breadcrumb-item>
    <el-breadcrumb-item>@AR["WeixinManager.Management"]</el-breadcrumb-item>
    <el-breadcrumb-item>{{docTitle}}</el-breadcrumb-item>
}

<div id="app" v-cloak>
    <div class="admin-role">
        <div class="filter-container">
            <template v-if="mpAccountDto">
                <el-button size="small" class="filter-item" type="primary" icon="el-icon-plus" :loading="addLoading" @@click="addUser('add')">@AR["Auto.UI.60e1bae1f8bb"]</el-button>
                <el-button size="small" class="filter-item" type="primary" @@click="asyncUser" :loading="isLoading"><i class="fa fa-exchange"></i> @AR["Auto.UI.c521327348cd"]</el-button>
                <el-button size="small" class="filter-item" type="danger" icon="el-icon-delete" @@click="del">@CR["Common.Delete"]</el-button>
                <span><small>@AR["Auto.UI.c592b1df7604"]</small></span>
            </template>
        </div>
        <el-table :data="tableData"
                  border
                  @@selection-change="handleSelectionChange"
                  style="width: 100%">
            <el-table-column type="selection"
                             align="center"
                             width="40">
            </el-table-column>
            <el-table-column align="center"
                             width="45"
                             label="#">
                <template slot-scope="scope">
                    {{ scope.row.id}}
                </template>
            </el-table-column>
            <el-table-column align="center"
                             label="@AR["Auto.UI.23eb0e6024b9"]">
                <template slot-scope="scope">
                    {{ scope.row.nickName}}
                </template>
            </el-table-column>
            <el-table-column align="center"
                             width="65"
                             label="@AR["Auto.UI.4c50eef3bdaf"]">
                <template slot-scope="scope">
                    <el-image style="width: 50px; height: 50px"
                              :src="scope.row.headImgUrl"></el-image>
                </template>
            </el-table-column>

            <el-table-column align="center"
                             label="@AR["Auto.UI.787b5677e325"]">
                <template slot-scope="scope">
                    <span v-if="scope.row.sex == 1">@AR["Auto.UI.36a4908a5577"]</span>
                    <span v-if="scope.row.sex == 2">@AR["Auto.UI.87c835a6b174"]</span>
                    <span v-if="scope.row.sex != 2 && scope.row.sex != 1">@CR["Common.Unknown"]</span>
                </template>
            </el-table-column>

            <el-table-column align="center"
                             label="@AR["Auto.UI.2560b304e691"]">
                <template slot-scope="scope">
                    {{scope.row.country}}&nbsp;
                    {{scope.row.province}}&nbsp;
                    {{scope.row.city}}
                </template>
            </el-table-column>

            <el-table-column align="center"
                             label="@AR["Auto.UI.829abe5a8dcd"]">
                <template slot-scope="scope">
                    {{ scope.row.groupid}}
                </template>
            </el-table-column>
            <el-table-column align="center"
                             label="@AR["Auto.UI.97f2bb62f566"]">
                <template slot-scope="scope">
                    {{ formaTableTime(scope.row.subscribe_Time)}}
                </template>
            </el-table-column>

            <el-table-column align="center"
                             label="@AR["Auto.UI.598726a25017"]">
                <template slot-scope="scope">
                    <span v-if="scope.row.subscribe == 1">@AR["Auto.UI.f4f38064f7a6"]</span>
                    <span v-if="scope.row.subscribe != 1">@AR["Auto.UI.149861e4243a"]</span>
                </template>
            </el-table-column>
            <el-table-column align="center"
                             label="@AR["Auto.UI.2070b871f390"]">
                <template slot-scope="scope">
                    {{scope.row.subscribe_Scene}}
                </template>
            </el-table-column>
            <el-table-column align="center"
                             label="@AR["Auto.UI.14d342362f66"]">
                <template slot-scope="scope">
                    <template v-if="scope.row.userTags_WeixinUsers.length == 0">
                        @AR["Auto.UI.d81bb206a889"]
                    </template>
                    <template v-if="scope.row.userTags_WeixinUsers.length > 0">
                        <ul>
                            <li v-for="item in scope.row.userTags_WeixinUsers">
                                {{item.userTag.name}}
                            </li>
                        </ul>
                    </template>
                </template>
            </el-table-column>
            <el-table-column align="center"
                             label="@CR["Common.Remark"]">
                <template slot-scope="scope">
                    {{scope.row.adminRemark}}
                </template>
            </el-table-column>
            <el-table-column align="center"
                             label="@CR["Common.Description"]">
                <template slot-scope="scope">
                    {{scope.row.adminRemark}}
                </template>
            </el-table-column>
            <el-table-column align="center"
                             width="145"
                             label="@CR["Common.AddTime"]">
                <template slot-scope="scope">
                    {{formaTableTime(scope.row.addTime)}}
                </template>
            </el-table-column>
            @*<el-table-column label="@CR["Common.Action"]" align="center" width="100"fixed="right">
                <template slot-scope="scope">
                    <el-popconfirm placement="top" title="@AR["Auto.UI.71d71cd9ca97"]" @@on-confirm="deleteCheck(scope.$index, scope.row)">
                        <el-button size="mini" type="danger" slot="reference">@CR["Common.Delete"]</el-button>
                    </el-popconfirm>
                </template>
            </el-table-column>*@
        </el-table>
        <pagination :total="searchData.total"
                    :page.sync="searchData.pageIndex"
                    :limit.sync="searchData.pageSize"
                    @@pagination="fetchData"></pagination>
    </div>
</div>

@section scripts {
    @*<script src="~/js/Admin/mpaccount.js"></script>*@
    <script>
        var app = new Vue({
            el: '#app',
            data: {
                searchData: {
                    pageIndex: 1,
                    pageSize: 10,
                    total: 0
                },
                tableData: [],
                mpAccountDto: null,
                uid: '',
                multipleSelection: [],
                docTitle: '',
                isLoading: false,
                addLoading:false
            },
            mounted() {
            },
            created() {
                this.fetchData();
                this.uid = resizeUrl().uid;
            },
            methods: {
                fetchData: function () {
                    var mpId = resizeUrl().mpid || null;
                    return service.get(`@Url.Page("Index")?handler=Ajax&pageIndex=${this.searchData.pageIndex}&pageSize=${this.searchData.pageSize}&mpId=${mpId}`).then(res => {
                        var responseData = res.data.data;
                        responseData.weixinUserDtos.list.map(ele => {
                            ele.selected = false;
                            //subscribe_Time
                            ele.subscribeTime = '';
                        })
                        this.tableData = responseData.weixinUserDtos.list;
                        this.mpAccountDto = responseData.mpAccountDto;
                        this.searchData.total = responseData.weixinUserDtos.count;
                        this.docTitle = this.mpAccountDto !== null ? this.mpAccountDto.name + '的用户' : '所有用户';
                        document.title = this.docTitle;
                    });
                },
                deleteCheck: function (index, row) {
                    //
                },
                addUser: function (synctype) {
                      if (synctype === 'all') {
                        this.isLoading = true;
                    } else {
                        this.addLoading = true;
                    }
                    var mpId = resizeUrl().mpid;
                    return service.get(`@Url.Page("Index")?handler=SyncUser&mpId=${mpId}&synctype=${synctype}`).then(res => {
                        this.isLoading = false;
                        this.addLoading = false;
                        return this.fetchData();
                    }).catch(e => {
                        this.isLoading = false;
                        this.addLoading = false;
                    });
                },
                asyncUser: function () {
                    this.addUser('all');
                },
                handleSelectionChange(val) {
                    this.multipleSelection = val;
                },
                del: function () {
                    var delIds = this.multipleSelection;
                    if (delIds.length === 0) {
                        this.$notify({
                            title: '警告',
                            message: '@AR["WeixinManager.PleaseSelectMpAccount"]',
                            type: 'warning',
                            duration: 2000
                        });
                        return;
                    }

                    var ids = [];
                    delIds.forEach(ele => {
                        ids.push(ele.id);
                    })

                    app.$confirm('是否删除所都选的项目？', { type: 'warning' }).then(res => {
                        return service.post('@Url.Page("Index")?handler=Delete', ids);
                    }).then(res => {
                        this.$notify({
                            title: '成功',
                            message: '已成功删除' + ids.length + '条',
                            type: 'success',
                            duration: 2000
                        });
                        return this.fetchData();
                    }).catch(e => {
                        //
                    })
                },
            }
        });
    </script>
}