@page
@model Senparc.Xncf.KnowledgeBase.Areas.Admin.Pages.KnowledgeBase.RecallTestModel
@{
    ViewData["Title"] = "召回测试";
    Layout = "_Layout_Vue";
}

@section Style {
    <link href="~/css/KnowledgeBase/RecallTest/RecallTest.css" rel="stylesheet" />
}

@section breadcrumbs {
    <el-breadcrumb-item>扩展模块</el-breadcrumb-item>
    <el-breadcrumb-item>知识库管理</el-breadcrumb-item>
    <el-breadcrumb-item>召回测试</el-breadcrumb-item>
}

<div id="app" class="recall-test-page">
    <div class="recall-test-wrap">
        <div class="recall-test-layout">
            <div class="recall-test-left">
                <h1 class="recall-test-title">召回测试</h1>
                <p class="recall-test-desc">根据给定的查询文本测试知识的召回效果。</p>

                <div class="knowledge-base-select-row">
                    <span class="kb-select-label">知识库</span>
                    <el-select v-model="selectedKnowledgeBaseId"
                               filterable
                               clearable
                               placeholder="输入关键字搜索并选择知识库"
                               class="kb-select"
                               @@focus="loadKnowledgeBaseList"
                               @@visible-change="onKbSelectVisibleChange">
                        <el-option v-for="item in knowledgeBaseList"
                                   :key="item.id"
                                   :label="item.name"
                                   :value="item.id">
                        </el-option>
                    </el-select>
                </div>

                <div class="source-text-box">
                <div class="source-text-header">
                    <span class="source-text-label">源文本</span>
                    <el-button type="text" size="small" class="inverted-index-btn" icon="el-icon-document" @@click="openSearchSettingsDrawer">倒排索引</el-button>
                </div>
                <div class="source-text-area-wrap">
                    <el-input type="textarea"
                              v-model="recallContent"
                              :maxlength="200"
                              :rows="10"
                              placeholder="请输入查询文本"
                              class="source-textarea"></el-input>
                    <div class="source-text-footer">
                        <span class="char-count">{{ recallContent.length }}/200</span>
                        <el-button type="primary" class="test-btn" @@click="doRecall" :loading="recallLoading" icon="el-icon-video-play">测试</el-button>
                    </div>
                </div>
            </div>

            <div class="records-section">
                <div class="records-title">记录</div>
                <el-table :data="recordList" size="small" border style="width:100%">
                    <el-table-column prop="queryContent" label="查询内容" min-width="120" show-overflow-tooltip></el-table-column>
                    <el-table-column prop="dataSource" label="数据源" width="140"></el-table-column>
                    <el-table-column prop="time" label="时间↓" width="160" align="center"></el-table-column>
                </el-table>
            </div>
        </div>

        <div class="recall-test-right">
            <div class="recall-result-title">{{ recallResults.length }} 个召回段落</div>
            <div class="recall-cards-wrap">
            <div class="recall-cards">
                <div v-for="(item, index) in recallResults" :key="index" class="recall-card">
                    <div class="recall-card-label">{{ item.chunkName || ('Chunk-' + String(index + 1).padStart(2, '0')) }} {{ item.charCount || (item.content ? item.content.length : 0) }} 字符</div>
                    <div class="recall-card-content">{{ item.content }}</div>
                    <div v-if="item.tags && item.tags.length" class="recall-card-tags">
                        <span v-for="(tag, ti) in item.tags" :key="ti" class="recall-tag">#{{ tag }}</span>
                    </div>
                    <div class="recall-card-source">
                        <i class="el-icon-document"></i>
                        <span>{{ item.sourceFile || '—' }}</span>
                    </div>
                    <el-button type="text" size="small" class="recall-card-open">打开 <i class="el-icon-right"></i></el-button>
                </div>
            </div>
            <div v-if="recallResults.length === 0" class="empty-result">暂无召回结果，请选择知识库、输入源文本并点击「测试」</div>
            </div>
        </div>
        </div>
    </div>

    @* 检索设置抽屉：点击倒排索引打开，可设置 Top K 并传给召回接口 *@
    <el-drawer title="检索设置"
               :visible.sync="visible.searchSettingsDrawer"
               direction="rtl"
               size="380px"
               :with-header="true"
               custom-class="search-settings-drawer">
        <div class="search-settings-body">
            <p class="search-settings-desc">了解更多关于检索方法。</p>
            <div class="search-settings-item">
                <div class="search-settings-label">检索方法</div>
                <div class="search-method-display"><i class="el-icon-document"></i> 倒排索引</div>
                <p class="search-method-tip">倒排索引是一种用于高效检索的结构。按术语组织，每个术语指向包含它的文档或网页。</p>
            </div>
            <div class="search-settings-item">
                <div class="search-settings-label">
                    Top K
                    <el-tooltip content="召回返回的片段数量" placement="top">
                        <i class="el-icon-question"></i>
                    </el-tooltip>
                </div>
                <div class="topk-row">
                    <el-slider v-model="topK" :min="1" :max="20" :step="1" show-stops style="flex:1;margin-right:16px;"></el-slider>
                    <el-input-number v-model="topK" :min="1" :max="20" :step="1" size="small" controls-position="right" style="width:100px;"></el-input-number>
                </div>
            </div>
        </div>
        <div class="search-settings-footer">
            <el-button size="small" @@click="visible.searchSettingsDrawer = false">取消</el-button>
            <el-button size="small" type="primary" @@click="saveSearchSettings">保存</el-button>
        </div>
    </el-drawer>

    <el-dialog title="属性管理" :visible.sync="visible.attrDialog" width="500px" @@close="closeAttrDialog">
        <el-button size="small" type="primary" @@click="addAttr" style="margin-bottom:10px">+ 新增属性</el-button>
        <el-table :data="attributeList" size="small" border>
            <el-table-column prop="name" label="属性名"></el-table-column>
            <el-table-column label="操作" width="150" align="center">
                <template slot-scope="scope">
                    <el-button type="text" size="small" @@click="editAttr(scope.row)">编辑</el-button>
                    <el-button type="text" size="small" class="danger" @@click="deleteAttr(scope.row)">删除</el-button>
                </template>
            </el-table-column>
        </el-table>
        <el-form v-if="visible.attrForm" label-width="80px" size="small" style="margin-top:12px">
            <el-form-item label="属性名">
                <el-input v-model="attrForm.name" placeholder="属性名"></el-input>
            </el-form-item>
            <el-form-item>
                <el-button type="primary" size="small" @@click="saveAttr">保存</el-button>
                <el-button size="small" @@click="visible.attrForm = false">取消</el-button>
            </el-form-item>
        </el-form>
        <div slot="footer">
            <el-button size="small" @@click="visible.attrDialog = false">关闭</el-button>
        </div>
    </el-dialog>

    <el-dialog title="标签管理" :visible.sync="visible.tagDialog" width="500px" @@close="closeTagDialog">
        <el-button size="small" type="primary" @@click="addTag" style="margin-bottom:10px">+ 新增标签</el-button>
        <el-table :data="tagList" size="small" border>
            <el-table-column prop="name" label="标签名"></el-table-column>
            <el-table-column label="操作" width="150" align="center">
                <template slot-scope="scope">
                    <el-button type="text" size="small" @@click="editTag(scope.row)">编辑</el-button>
                    <el-button type="text" size="small" class="danger" @@click="deleteTag(scope.row)">删除</el-button>
                </template>
            </el-table-column>
        </el-table>
        <el-form v-if="visible.tagForm" label-width="80px" size="small" style="margin-top:12px">
            <el-form-item label="标签名">
                <el-input v-model="tagForm.name" placeholder="标签名"></el-input>
            </el-form-item>
            <el-form-item>
                <el-button type="primary" size="small" @@click="saveTag">保存</el-button>
                <el-button size="small" @@click="visible.tagForm = false">取消</el-button>
            </el-form-item>
        </el-form>
        <div slot="footer">
            <el-button size="small" @@click="visible.tagDialog = false">关闭</el-button>
        </div>
    </el-dialog>
</div>

@section scripts
{
    <script src="~/js/KnowledgeBase/Pages/RecallTest/recallTest.js"></script>
}
