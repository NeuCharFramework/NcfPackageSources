@page
@model Senparc.Xncf.KnowledgeBase.Areas.Admin.Pages.KnowledgeBase.RecallTestModel
@inject Microsoft.Extensions.Localization.IStringLocalizerFactory LocalizerFactory
@{
    var AR = LocalizerFactory.Create("Senparc.Areas.Admin.Resources.AdminResource", "Senparc.Areas.Admin");
    ViewData["Title"] = AR["KnowledgeBase.RecallTest"];
    Layout = "_Layout_Vue";
}

@section Style {
    <link href="~/css/KnowledgeBase/RecallTest/RecallTest.css" rel="stylesheet" />
}

@section breadcrumbs {
    <el-breadcrumb-item>@AR["Common.ExtensionModules"]</el-breadcrumb-item>
    <el-breadcrumb-item>@AR["KnowledgeBase.Management"]</el-breadcrumb-item>
    <el-breadcrumb-item>@AR["KnowledgeBase.RecallTest"]</el-breadcrumb-item>
}

<div id="app" class="recall-test-page">
    <div class="recall-test-wrap">
        <div class="recall-test-layout">
            <div class="recall-test-left">
                <h1 class="recall-test-title">@AR["KnowledgeBase.RecallTest"]</h1>
                <p class="recall-test-desc">@AR["Auto.UI.a29c28054a06"]</p>

                <div class="knowledge-base-select-row">
                    <span class="kb-select-label">@AR["KnowledgeBase.KnowledgeBase"]</span>
                    <el-select v-model="selectedKnowledgeBaseId"
                               filterable
                               clearable
                               placeholder="@AR["KnowledgeBase.SearchSelectKnowledgeBase"]"
                               class="kb-select"
                               @@focus="loadKnowledgeBaseList"
                               @@visible-change="onKbSelectVisibleChange">
                        <el-option v-for="item in knowledgeBaseList"
                                   :key="item.id"
                                   :label="item.name"
                                   :value="item.id">
                        </el-option>
                    </el-select>
                </div>

                <div class="source-text-box">
                    <div class="source-text-header">
                        <span class="source-text-label">@AR["KnowledgeBase.SourceText"]</span>
                        <el-button type="text" size="small" class="inverted-index-btn" icon="el-icon-document" @@click="openSearchSettingsDrawer">@AR["KnowledgeBase.InvertedIndex"]</el-button>
                    </div>
                    <div class="source-text-area-wrap">
                        <el-input type="textarea"
                                  v-model="recallContent"
                                  :maxlength="200"
                                  :rows="10"
                                  placeholder="@AR["KnowledgeBase.PleaseInputQueryText"]"
                                  class="source-textarea"></el-input>
                        <div class="source-text-footer">
                            <span class="char-count">{{ recallContent.length }}/200</span>
                            <el-button type="primary" class="test-btn" @@click="doRecall" :loading="recallLoading" icon="el-icon-video-play">@AR["Auto.UI.db06c78d1e24"]</el-button>
                        </div>
                    </div>
                </div>

                <div class="records-section">
                    <div class="records-title">@AR["Auto.UI.620bf82011e0"]</div>
                    <div class="records-table-wrap">
                        <el-table :data="recordPageList"
                                  size="small"
                                  border
                                  class="records-table"
                                  :height="recordTableHeight">
                            <el-table-column prop="queryContent" label="@AR["KnowledgeBase.QueryContent"]" min-width="100" show-overflow-tooltip></el-table-column>
                            <el-table-column label="@AR["KnowledgeBase.RecallRate"]" min-width="100" show-overflow-tooltip>
                                <template slot-scope="scope">{{ scope.row.score != null && scope.row.score !== '' ? scope.row.score : '—' }}</template>
                            </el-table-column>
                            <el-table-column prop="dataSource" label="@AR["KnowledgeBase.DataSource"]" width="120" show-overflow-tooltip></el-table-column>
                            <el-table-column prop="time" label="@AR["Auto.UI.58795001de8c"]" width="140" align="center"></el-table-column>
                        </el-table>
                    </div>
                    <el-pagination class="records-pagination"
                                   :current-page.sync="recordPage"
                                   :page-sizes="[5, 10, 15, 20]"
                                   :page-size.sync="recordPageSize"
                                   :total="recordTotal"
                                   layout="total, sizes, prev, pager, next, jumper"
                                   @@size-change="handleRecordSizeChange"
                                   @@current-change="handleRecordPageChange">
                    </el-pagination>
                </div>
            </div>

            <div class="recall-test-right">
                <div class="recall-result-title">{{ recallResults.length }} 个召回段落</div>
                <div class="recall-cards-wrap">
                    <div class="recall-cards">
                        <div v-for="(item, index) in recallResults" :key="index" class="recall-card">
                            <div class="recall-card-label">{{ item.chunkName || ('Chunk-' + String(index + 1).padStart(2, '0')) }} {{ item.charCount || (item.content ? item.content.length : 0) }} 字符</div>
                            <div class="recall-card-content">{{ item.content }}</div>
                            @* <div v-if="item.tags && item.tags.length" class="recall-card-tags">
                        <span v-for="(tag, ti) in item.tags" :key="ti" class="recall-tag">#{{ tag }}</span>
                    </div>
                    <div class="recall-card-source">
                        <i class="el-icon-document"></i>
                        <span>{{ item.sourceFile || '—' }}</span>
                    </div> *@
                            <el-button type="text" size="small" class="recall-card-open" @@click="openParagraphDetail(item, index)">@AR["Auto.UI.d7098f5050f0"] <i class="el-icon-right"></i></el-button>
                        </div>
                    </div>
                    <div v-if="recallResults.length === 0" class="empty-result">@AR["Auto.UI.fda22f61050e"]</div>
                </div>
            </div>
        </div>
    </div>

    @* 检索设置抽屉：点击倒排索引打开，可设置 Top K 并传给召回接口 *@
    <el-drawer title="@AR["KnowledgeBase.SearchSettings"]"
               :visible.sync="visible.searchSettingsDrawer"
               direction="rtl"
               size="380px"
               :with-header="true"
               custom-class="search-settings-drawer">
        <div class="search-settings-body">
            <p class="search-settings-desc">@AR["Auto.UI.9df07adec0bd"]</p>
            <div class="search-settings-item">
                <div class="search-settings-label">@AR["KnowledgeBase.SearchMethod"]</div>
                <div class="search-method-display"><i class="el-icon-document"></i> @AR["Auto.UI.07ec4f380dcb"]</div>
                <p class="search-method-tip">@AR["Auto.UI.5ef0ecb63a58"]</p>
            </div>
            <div class="search-settings-item">
                <div class="search-settings-label">
                    Top K
                    <el-tooltip content="召回返回的片段数量" placement="top">
                        <i class="el-icon-question"></i>
                    </el-tooltip>
                </div>
                <div class="topk-row">
                    <el-slider v-model="topK" :min="1" :max="20" :step="1" show-stops style="flex:1;margin-right:16px;"></el-slider>
                    <el-input-number v-model="topK" :min="1" :max="20" :step="1" size="small" controls-position="right" style="width:100px;"></el-input-number>
                </div>
            </div>
        </div>
        <div class="search-settings-footer">
            <el-button size="small" @@click="visible.searchSettingsDrawer = false">@AR["Common.Cancel"]</el-button>
            <el-button size="small" type="primary" @@click="saveSearchSettings">@AR["Common.Save"]</el-button>
        </div>
    </el-drawer>

    @* 段落详情弹框：点击召回片段「打开」显示 *@
    <el-dialog title="@AR["KnowledgeBase.ParagraphDetail"]"
               :visible.sync="visible.paragraphDetailDialog"
               width="560px"
               custom-class="paragraph-detail-dialog"
               @@close="paragraphDetailItem = null">
        <template v-if="paragraphDetailItem">
            <div class="paragraph-detail-chunk">{{ paragraphDetailChunkName }}</div>
            @* <div class="paragraph-detail-source">
                <i class="el-icon-document"></i>
                <span>{{ paragraphDetailItem.sourceFile || '—' }}</span>
            </div> *@
            <div class="paragraph-detail-title" v-if="paragraphDetailItem.title">{{ paragraphDetailItem.title }}</div>
            <div class="paragraph-detail-content">{{ paragraphDetailItem.content || '—' }}</div>
            <div class="paragraph-detail-keywords" v-if="paragraphDetailTags.length">
                <span class="paragraph-detail-keywords-label">@AR["Common.Keywords"]</span>
                <div class="paragraph-detail-tags">
                    <span v-for="(tag, ti) in paragraphDetailTags" :key="ti" class="recall-tag">#{{ tag }}</span>
                </div>
            </div>
        </template>
    </el-dialog>

    <el-dialog title="@AR["KnowledgeBase.AttrManagement"]" :visible.sync="visible.attrDialog" width="500px" @@close="closeAttrDialog">
        <el-button size="small" type="primary" @@click="addAttr" style="margin-bottom:10px">@AR["Auto.UI.17914471fa31"]</el-button>
        <el-table :data="attributeList" size="small" border>
            <el-table-column prop="name" label="@AR["KnowledgeBase.AttrName"]"></el-table-column>
            <el-table-column label="@AR["Common.Action"]" width="150" align="center">
                <template slot-scope="scope">
                    <el-button type="text" size="small" @@click="editAttr(scope.row)">@AR["Common.Edit"]</el-button>
                    <el-button type="text" size="small" class="danger" @@click="deleteAttr(scope.row)">@AR["Common.Delete"]</el-button>
                </template>
            </el-table-column>
        </el-table>
        <el-form v-if="visible.attrForm" label-width="80px" size="small" style="margin-top:12px">
            <el-form-item label="@AR["KnowledgeBase.AttrName"]">
                <el-input v-model="attrForm.name" placeholder="@AR["KnowledgeBase.AttrName"]"></el-input>
            </el-form-item>
            <el-form-item>
                <el-button type="primary" size="small" @@click="saveAttr">@AR["Common.Save"]</el-button>
                <el-button size="small" @@click="visible.attrForm = false">@AR["Common.Cancel"]</el-button>
            </el-form-item>
        </el-form>
        <div slot="footer">
            <el-button size="small" @@click="visible.attrDialog = false">@AR["Common.Close"]</el-button>
        </div>
    </el-dialog>

    <el-dialog title="@AR["KnowledgeBase.TagManagement"]" :visible.sync="visible.tagDialog" width="500px" @@close="closeTagDialog">
        <el-button size="small" type="primary" @@click="addTag" style="margin-bottom:10px">@AR["Auto.UI.abe2cdff0070"]</el-button>
        <el-table :data="tagList" size="small" border>
            <el-table-column prop="name" label="@AR["KnowledgeBase.TagName"]"></el-table-column>
            <el-table-column label="@AR["Common.Action"]" width="150" align="center">
                <template slot-scope="scope">
                    <el-button type="text" size="small" @@click="editTag(scope.row)">@AR["Common.Edit"]</el-button>
                    <el-button type="text" size="small" class="danger" @@click="deleteTag(scope.row)">@AR["Common.Delete"]</el-button>
                </template>
            </el-table-column>
        </el-table>
        <el-form v-if="visible.tagForm" label-width="80px" size="small" style="margin-top:12px">
            <el-form-item label="@AR["KnowledgeBase.TagName"]">
                <el-input v-model="tagForm.name" placeholder="@AR["KnowledgeBase.TagName"]"></el-input>
            </el-form-item>
            <el-form-item>
                <el-button type="primary" size="small" @@click="saveTag">@AR["Common.Save"]</el-button>
                <el-button size="small" @@click="visible.tagForm = false">@AR["Common.Cancel"]</el-button>
            </el-form-item>
        </el-form>
        <div slot="footer">
            <el-button size="small" @@click="visible.tagDialog = false">@AR["Common.Close"]</el-button>
        </div>
    </el-dialog>
</div>

@section scripts
{
    <script src="~/js/KnowledgeBase/Pages/RecallTest/recallTest.js"></script>
}
