@page
@model Senparc.Xncf.KnowledgeBase.Areas.Admin.Pages.KnowledgeBase.IndexModel
@{
    ViewData["Title"] = "知识库管理列表页面";
    Layout = "_Layout_Vue";
}

@section Style {
    <link href="~/css/KnowledgeBase/KnowledgeBase/KnowledgeBase.css" rel="stylesheet" />
}

@section breadcrumbs {
    <el-breadcrumb-item>扩展模块</el-breadcrumb-item>
    <el-breadcrumb-item>知识库管理</el-breadcrumb-item>
    <el-breadcrumb-item>知识库列表</el-breadcrumb-item>
}

<div class="kb-index-page">
    <div class="admin-role">
        @* 查询区：按知识库名称查询 *@
        <div class="kb-query-section">
            <div class="kb-query-row">
                <label class="kb-query-label">知识库名称</label>
                <el-input v-model="keyword"
                          placeholder="请输入知识库名称关键字"
                          size="small"
                          clearable
                          class="kb-query-input"
                          @@keyup.enter.native="handleSearch()"></el-input>
                <el-button type="primary" size="small" icon="el-icon-search" @@click="handleSearch()">查询</el-button>
                <el-button size="small" icon="el-icon-refresh-left" @@click="resetCondition()">重置</el-button>
            </div>
        </div>

        @* 工具栏：添加按钮、列筛选 *@
        <div class="kb-toolbar">
            <el-button type="primary" size="small" icon="el-icon-plus" @@click="handleEdit('','','add')">添加</el-button>
            <el-popover placement="bottom" title="筛选列" trigger="click" width="200">
                <el-checkbox-group v-model="checkedColumns" size="small">
                    <el-checkbox v-for="item in checkBoxGroup" :key="item" :label="item" :value="item"></el-checkbox>
                </el-checkbox-group>
                <el-button slot="reference" size="small" plain icon="el-icon-s-operation">列筛选</el-button>
            </el-popover>
        </div>

        @* 表格区域 *@
        <div class="kb-table-wrap">
        <el-table :data="tableData"
                  style="width:100%;"
                  size="small"
                  row-key="id"
                  border
                  ref="multipleTable"
                  @@selection-change="handleSelectionChange"
                  @@row-dblclick="handleDbClick">
            <el-table-column type="selection" width="55"></el-table-column>
            <el-table-column v-if="colData[0].istrue" prop="embeddingModelId" align="left" label="Embedding模型Id" sortable :filters="filterTableHeader.embeddingModelId" :filter-method="filterHandler"></el-table-column>

            <el-table-column v-if="colData[1].istrue" prop="vectorDBId" align="left" label="向量数据库Id" sortable :filters="filterTableHeader.vectorDBId" :filter-method="filterHandler"></el-table-column>

            <el-table-column v-if="colData[2].istrue" prop="chatModelId" align="left" label="对话模型Id" sortable :filters="filterTableHeader.chatModelId" :filter-method="filterHandler"></el-table-column>

            <el-table-column v-if="colData[3].istrue" prop="name" align="left" label="名称" sortable :filters="filterTableHeader.name" :filter-method="filterHandler"></el-table-column>

            <el-table-column v-if="colData[4].istrue" prop="content" align="left" label="内容" sortable :filters="filterTableHeader.content" :filter-method="filterHandler"></el-table-column>

            <el-table-column align="center"
                             label="添加时间" sortable>
                <template slot-scope="scope">
                    {{formaTableTime(scope.row.addTime)}}
                </template>
            </el-table-column>
            <el-table-column label="操作" align="center" fixed="right" width="320">
                <template slot-scope="scope">
                    <el-button size="mini" type="primary" plain @@click="handleElVisibleOpenBtn('drawerGroup',scope.row)">配置</el-button>
                    <el-button size="mini" type="primary" plain @@click="handleEmbeddingBtn('embedding',scope.row)">向量化</el-button>
                    <el-button size="mini" type="primary" plain @@click="handleEdit(scope.$index, scope.row,'edit')">编辑</el-button>
                    <el-popconfirm placement="top" title="确认删除此知识库吗？" @@on-confirm="handleDelete(scope.$index, scope.row)">
                        <el-button size="mini" type="danger" plain slot="reference">删除</el-button>
                    </el-popconfirm>
                </template>
            </el-table-column>
        </el-table>
        </div>

        @* 分页：首页、上一页、下一页、尾页、跳转、每页条数 5/10/15/20/50/100，默认 10 *@
        <div class="kb-pagination-wrap">
            <el-pagination :current-page.sync="listQuery.pageIndex"
                          :page-sizes="[5, 10, 15, 20, 50, 100]"
                          :page-size.sync="listQuery.pageSize"
                          :total="paginationQuery.total"
                          layout="total, sizes, prev, pager, next, jumper"
                          @@size-change="handlePageSizeChange"
                          @@current-change="handlePageChange">
            </el-pagination>
        </div>
        <!--编辑、新增-->
        <el-dialog :title="dialog.title"
                   :visible.sync="dialog.visible"
                   :close-on-click-modal="false"
                   width="600px">
            <el-form ref="dataForm"
                     :rules="dialog.rules"
                     :model="dialog.data"
                     :disabled="dialog.disabled"
                     size="mini"
                     label-position="left"
                     label-width="150px"
                     style="max-width: 600px; margin-left:50px;">
                <el-form-item label="名称" prop="name">
                    <el-input size="mini" v-model="dialog.data.name" clearable placeholder="请输入名称" />
                </el-form-item>

                <el-form-item label="选择Embedding模型">
                    <el-cascader v-model="selectDefaultEmbeddingModel"
                                 :options="embeddingModelData"
                                 @@change="selectEmbeddingModel"
                                 clearable
                                 filterable
                                 :props="{label:'alias',value:'id'}">
                    </el-cascader>
                </el-form-item>

                <el-form-item label="Embedding模型Id" prop="embeddingModelId" class="hidden">
                    <el-input size="mini" v-model="dialog.data.embeddingModelId" clearable placeholder="请输入Embedding模型Id" />
                </el-form-item>

                <el-form-item label="选择向量数据库">
                    <el-cascader v-model="selectDefaultVectorDB"
                                 :options="vectorDBData"
                                 @@change="selectVectorDB"
                                 clearable
                                 filterable
                                 :props="{label:'alias',value:'id'}">
                    </el-cascader>
                </el-form-item>

                <el-form-item label="向量数据库Id" prop="vectorDBId" class="hidden">
                    <el-input size="mini" v-model="dialog.data.vectorDBId" clearable placeholder="请输入向量数据库Id" />
                </el-form-item>

                <el-form-item label="选择对话模型">
                    <el-cascader v-model="selectDefaultChatModel"
                                 :options="chatModelData"
                                 @@change="selectChatModel"
                                 clearable
                                 filterable
                                 :props="{label:'alias',value:'id'}">
                    </el-cascader>
                </el-form-item>

                <el-form-item label="对话模型Id" prop="chatModelId" class="hidden">
                    <el-input size="mini" v-model="dialog.data.chatModelId" clearable placeholder="请输入对话模型Id" />
                </el-form-item>

                <el-form-item label="内容" prop="content">
                    <el-input type="textarea" size="mini" v-model="dialog.data.content" clearable placeholder="请输入内容" />
                </el-form-item>
            </el-form>
            <div slot="footer" class="dialog-footer">
                <el-button size="mini" @@click="dialog.visible=false">取消</el-button>
                <el-button size="mini" :loading="dialog.updateLoading" :disabled="dialog.disabled" type="primary" @@click="updateData">确认</el-button>
            </div>
        </el-dialog>

        @* 抽屉 新增|编辑 知识库关联 *@
        <el-drawer :visible.sync="visible.drawerGroup" direction="rtl" :with-header="false" :wrapper-closable="false"
                   :close-on-press-escape="false" size="960px">
            <div class="drawerRtl">
                @* 内容中的头（包括标题和关闭图标） *@
                <div class="drawerRtl__header">
                    <div class="drawerRtl__header__title">{{ groupForm.id ? '编辑知识库关联' : '新增知识库关联' }} </div>
                    <div class="drawerRtl__header__close" @@click="handleElVisibleClose('drawerGroup')">&times;</div>
                </div>
                @* 内容中的主体内容 *@
                <div class="drawerRtl__body">
                    <el-form v-if="visible.drawerGroup" ref="groupELForm" :model="groupForm" :rules="groupFormRules"
                             :size="elSize" label-position="left" label-width="130px" class="drawerForm-container">
                        <el-form-item label="内容类型">
                            <el-select size="mini" v-model="groupForm.contentType" placeholder="请选择内容类型">
                                <el-option v-for="item in contentTypeData" :key="item.value" :label="item.label" :value="item.value"></el-option>
                            </el-select>
                        </el-form-item>
                        <el-form-item v-if="groupForm.contentType === 2" label="文件列表" prop="files">
                            <div class="groupFMB">
                                <div class="df-wn flex-ac flex-jsb" style="gap: 10px;margin-bottom: 10px;">
                                    <div class="df-wn flex-ac" style="gap: 10px;">
                                        <el-input v-model="fileQueryList.filter" size="small"
                                                  placeholder="文件名称" style="width:auto;"></el-input>
                                        <el-button size="small" icon="el-icon-search"
                                                   @@click="handleConfigFileSearch">搜索</el-button>
                                    </div>
                                </div>
                                <div class="df-wn flex-ac flex-jsb" style="gap: 10px;margin-bottom: 10px;">
                                    <div class="df-wn flex-ac" style="gap: 10px;">
                                        <el-button size="small" type="primary" icon="el-icon-upload2"
                                                   @@click="handleElVisibleOpenBtn('dialogFile')">上传文件</el-button>
                                        <el-button size="small" type="danger" icon="el-icon-delete"
                                                   @@click="handleConfigFileBatchDelete">批量删除</el-button>
                                    </div>
                                </div>
                                <div class="df-wn flex-as flex-js" style="gap: 10px;margin-bottom: 10px;">
                                    <span class="groupFMB_ma_label">已选择:</span>
                                    <div class="groupFMB_ma_list">
                                        <div class="df flex-ac flex-js" style="gap:10px">
                                            <div v-for="(item,index) in groupForm.files" :key="item.id"
                                                 class="df-wn flex-ac groupFMB_ma_list_item">
                                                <span class="groupFMB_ma_list_item_text">{{ item.name }}</span>
                                                <i class="el-icon-close cursorPointer"
                                                   @@click="groupMembersCancel(item,index)"></i>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <el-table ref="groupAgentTable" key="groupAgentTable" :data="fileList" max-height="380"
                                          style="width: 100%;margin-bottom: 10px;border: 1px solid rgba(229, 229, 229, 1);"
                                          @@selection-change="handleConfigFileSelectionChange">
                                    <el-table-column type="selection" width="30"></el-table-column>
                                    <el-table-column prop="fileName" label="文件名" width="200"
                                                     show-overflow-tooltip></el-table-column>
                                    <el-table-column prop="fileSize" label="文件大小" width="100">
                                    </el-table-column>
                                    <el-table-column label="上传时间" width="130" align="center">
                                        <template slot-scope="scope">
                                            {{ formaTableTime(scope.row.uploadTime) }}
                                        </template>
                                    </el-table-column>
                              @*       <el-table-column prop="description" label="描述" min-width="100">
                                    </el-table-column> *@
                                    <el-table-column fixed="right" label="操作" width="130">
                                        <template slot-scope="{ row }">
                                            @* <el-button type="primary" size="small"
                                                       @@click="handleEditDrawerOpenBtn('dialogGroupAgent',row)">编辑</el-button> *@
                                            <el-button type="danger" size="small"
                                                       @@click="handleConfigFileDelete(row)">删除</el-button>
                                        </template>
                                    </el-table-column>
                                </el-table>
                                <div class="df-wn flex-ac flex-jsb" style="margin-top:10px;flex-wrap:wrap;gap:8px;">
                                    <span class="el-pagination__total" style="margin-right:12px;">当前选中 {{ groupForm.files.length }} 行</span>
                                    <el-pagination :current-page.sync="fileQueryList.pageIndex"
                                                   :page-size="fileQueryList.pageSize"
                                                   :page-sizes="[10, 20, 50,100]"
                                                   :total="fileListTotal"
                                                   layout="total, sizes, prev, pager, next, jumper"
                                                   @@size-change="handleConfigFileSizeChange"
                                                   @@current-change="handleConfigFilePageChange">
                                    </el-pagination>
                                </div>
                            </div>
                        </el-form-item>
                        <el-form-item v-if="groupForm.contentType === 1 || groupForm.contentType === 3" label="内容">
                            <el-input type="textarea" v-model="groupForm.content" :rows="4" placeholder="请填写"></el-input>
                        </el-form-item>
                    </el-form>
                </div>
                @* 内容中固定的footer *@
                <div class="drawerRtl__footer text-right">
                    <el-button :size="elSize" @@click="handleElVisibleClose('drawerGroup')">取消</el-button>
                    <el-button :size="elSize" type="primary" @@click="handleElVisibleSubmit('drawerGroup')">确认</el-button>
                </div>
            </div>
        </el-drawer>

        @* 配置页内「新建文件」上传弹框：选择文件后调用上传接口写入 FileManage，保存时与知识库关联 *@
        <el-dialog title="新建文件"
                   :visible.sync="visible.dialogFile"
                   width="480px"
                   :close-on-click-modal="false"
                   @@close="handleDialogFileClose">
            <el-upload class="upload-demo"
                       ref="configUploadRef"
                       action="/api/Senparc.Xncf.KnowledgeBase/CommonService/Xncf.KnowledgeBase_CommonService.UploadAsync"
                       :auto-upload="true"
                       :multiple="true"
                       :show-file-list="true"
                       :on-success="configUploadSuccess"
                       :on-error="configUploadError"
                       :file-list="configUploadFileList">
                <el-button slot="trigger" size="small" type="primary">选择文件</el-button>
                <div slot="tip" class="el-upload__tip">选择文件后将上传至文件管理，并可在下方文件列表中勾选后与当前知识库关联</div>
            </el-upload>
            <div slot="footer" class="dialog-footer">
                <el-button size="mini" @@click="visible.dialogFile = false">关闭</el-button>
            </div>
        </el-dialog>

        @* 向量化进度弹窗 *@
        <el-dialog title="向量化进度"
                   :visible.sync="visible.embeddingProgress"
                   width="420px"
                   :close-on-click-modal="false"
                   :close-on-press-escape="false"
                   :show-close="false">
            <div class="embedding-progress-body">
                <el-progress :percentage="embeddingProgressPercent" :status="embeddingProgressStatus"></el-progress>
                <p class="embedding-progress-text">{{ embeddingProgressText }}</p>
            </div>
        </el-dialog>

        @* 向量化结果展示弹窗 *@
        <el-dialog title="向量化结果"
                   :visible.sync="visible.embeddingResult"
                   width="560px"
                   @@close="embeddingResultText = ''">
            <div class="embedding-result-body">
                <pre class="embedding-result-pre">{{ embeddingResultText }}</pre>
            </div>
            <div slot="footer" class="dialog-footer">
                <el-button type="primary" size="small" @@click="visible.embeddingResult = false; getList()">确定</el-button>
            </div>
        </el-dialog>
    </div>
</div>
@section scripts
{
    <script src="~/js/KnowledgeBase/Pages/KnowledgeBase/knowledgeBase.js"></script>
}