@page
@model Senparc.Xncf.SenMapic.Areas.Admin.Pages.SenMapic.Task.IndexModel
@inject Microsoft.Extensions.Localization.IStringLocalizerFactory LocalizerFactory
@{    var AR = LocalizerFactory.Create("Senparc.Areas.Admin.Resources.AdminResource", "Senparc.Areas.Admin");
    var CR = LocalizerFactory.Create("Senparc.Ncf.XncfBase.Resources.CommonResource", "Senparc.Ncf.XncfBase");

    ViewData["Title"] = AR["Auto.UI.481ff04e318a"];
}

<div class="admin-site">
    <div class="admin-site-header">
        <el-breadcrumb separator="/">
            <el-breadcrumb-item>@CR["Common.Home"]</el-breadcrumb-item>
            <el-breadcrumb-item>@AR["Auto.UI.481ff04e318a"]</el-breadcrumb-item>
        </el-breadcrumb>
    </div>

    <div class="admin-site-content">
        <div class="admin-site-content-header">
            <el-button type="primary" size="small" @@click="handleAdd">@AR["Auto.UI.b255a277b38c"]</el-button>
        </div>

        <div class="admin-site-content-body">
            <el-table :data="tableData" style="width: 100%" v-loading="loading">
                <el-table-column prop="name" label="@AR["Auto.UI.78caf7115c51"]" width="180"></el-table-column>
                <el-table-column prop="startUrl" label="@AR["Auto.UI.e0ce8b1afd79"]" width="280"></el-table-column>
                <el-table-column prop="maxThread" label="@AR["Auto.UI.0a144ec2f000"]" width="120"></el-table-column>
                <el-table-column prop="maxBuildMinutes" label="@AR["Auto.UI.ee0f8b291cbd"]" width="160"></el-table-column>
                <el-table-column prop="maxDeep" label="@AR["Auto.UI.1752d7642a12"]" width="120"></el-table-column>
                <el-table-column prop="maxPageCount" label="@AR["Auto.UI.c3e00bdc8118"]" width="120"></el-table-column>
                <el-table-column prop="status" label="@AR["Auto.UI.3fea7ca76cde"]" width="120">
                    <template slot-scope="scope">
                        <el-tag :type="getStatusType(scope.row.status)">{{getStatusText(scope.row.status)}}</el-tag>
                    </template>
                </el-table-column>
                <el-table-column label="@CR["Common.Action"]" width="200">
                    <template slot-scope="scope">
                        <el-button size="mini" type="primary" @@click="handleStart(scope.row)" 
                                 :disabled="scope.row.status !== 0">@AR["Auto.UI.a3e3b88377c8"]</el-button>
                        <el-button size="mini" type="danger" @@click="handleDelete(scope.row)">@CR["Common.Delete"]</el-button>
                    </template>
                </el-table-column>
            </el-table>
        </div>
    </div>

    <!-- 新增/编辑对话框 -->
    <el-dialog :title="dialogTitle" :visible.sync="dialogVisible" width="50%">
        <el-form :model="form" :rules="rules" ref="form" label-width="120px">
            <el-form-item label="@AR["Auto.UI.78caf7115c51"]" prop="name">
                <el-input v-model="form.name"></el-input>
            </el-form-item>
            <el-form-item label="@AR["Auto.UI.e0ce8b1afd79"]" prop="startUrl">
                <el-input v-model="form.startUrl"></el-input>
            </el-form-item>
            <el-form-item label="@AR["Auto.UI.0a144ec2f000"]" prop="maxThread">
                <el-input-number v-model="form.maxThread" :min="1" :max="10"></el-input-number>
            </el-form-item>
            <el-form-item label="@AR["Auto.UI.0ae465d802bd"]" prop="maxBuildMinutes">
                <el-input-number v-model="form.maxBuildMinutes" :min="1" :max="60"></el-input-number>
            </el-form-item>
            <el-form-item label="@AR["Auto.UI.1752d7642a12"]" prop="maxDeep">
                <el-input-number v-model="form.maxDeep" :min="1" :max="10"></el-input-number>
            </el-form-item>
            <el-form-item label="@AR["Auto.UI.c3e00bdc8118"]" prop="maxPageCount">
                <el-input-number v-model="form.maxPageCount" :min="1" :max="1000"></el-input-number>
            </el-form-item>
            <el-form-item label="@AR["Auto.UI.54adb5ae4a15"]">
                <el-switch v-model="form.startImmediately"></el-switch>
            </el-form-item>
        </el-form>
        <div slot="footer" class="dialog-footer">
            <el-button @@click="dialogVisible = false">@CR["Common.Cancel"]</el-button>
            <el-button type="primary" @@click="handleSubmit">@CR["Common.Confirm"]</el-button>
        </div>
    </el-dialog>
</div>

@section scripts{
    <script src="~/js/SenMapic/task.js"></script>
} 