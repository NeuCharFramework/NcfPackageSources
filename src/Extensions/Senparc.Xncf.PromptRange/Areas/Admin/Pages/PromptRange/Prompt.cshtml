@page
@model Senparc.Xncf.PromptRange.Areas.Admin.Pages.PromptRange.PromptModel
@inject Microsoft.Extensions.Localization.IStringLocalizerFactory LocalizerFactory
@{
    ViewData["Title"] = "PromptRange Prompt";
    Layout = "_Layout_Vue";
    var AR = LocalizerFactory.Create("Senparc.Areas.Admin.Resources.AdminResource", "Senparc.Areas.Admin");
    var CR = LocalizerFactory.Create("Senparc.Ncf.XncfBase.Resources.CommonResource", "Senparc.Ncf.XncfBase");
}

@section Style {
    <link href="~/css/PromptRange/prompt.css" rel="stylesheet" />
    <meta http-equiv="Content-Security-Policy" content="upgrade-insecure-requests">
}

@section breadcrumbs {
    <el-breadcrumb-item>@CR["Common.ExtensionModules"]</el-breadcrumb-item>
    <el-breadcrumb-item>@AR["PromptRange.ModuleName"]</el-breadcrumb-item>
    <el-breadcrumb-item>Prompt</el-breadcrumb-item>
}


<div class="promptPage">
    @* Left Side Input Test *@
    <div class="promptPage_leftArea" 
         :class="{'promptPage_leftAreaHide':promptLeftShow}"
         :style="!promptLeftShow && !centerAreaMaximized && !rightAreaMaximized ? {width: leftAreaWidth + 'px'} : {}">
        @* Configuration *@
        <div class="boxCard configurineArea" v-if="isBoxVisible">
            @* Select Range *@
            <div class="configurineAreaItem rangeBox">
                <div class="d-flex align-flex-end" style="gap: 10px">
                    <div class="w-100">
                        <div class="d-flex align-center justify-content-between" style="gap: 5px;margin-bottom: 5px">
                            <div class="d-flex align-center">
                                <img src="~/image/PromptRange/prompt_selectPrompt.svg" alt="" class="imgIcon" />
                                <div class="titleContent">@AR["Auto.UI.4b47e14823ea"]</div>
                            </div>
                            <div>
                                <el-button type="primary" size="mini" @@click="expectedPluginOpen">@AR["Auto.UI.4b18e4801fa1"]</el-button>
                                <el-button type="primary" size="mini" @@click="uploadPluginVisible = true">@AR["Auto.UI.83cdd84a13a4"]</el-button>
                                <el-button type="primary" size="mini" icon="el-icon-plus" @@click="addPromptField">@AR["Auto.UI.0e5b359fd09a"]</el-button>
                            </div>

                        </div>
                        <el-select v-model="promptField" filterable placeholder="@AR["Auto.UI.1902333eff98"]" :popper-append-to-body="true" class="selectRow" @@change="promptChangeHandel($event,'promptField')">
                            <el-option v-for="item in promptFieldOpt"
                                       v-key="item.id"
                                       :label="item.label"
                                       :value="item.value"
                                       :disabled="item.disabled">
                                <div class="d-flex justify-content-between align-center">
                                    <span>{{ item.label }}</span>
                                    <div>

                                        <el-button type="primary" size="mini" @@click="renameField($event,item)">@AR["Auto.UI.e533aeffac22"]</el-button>
                                        <el-button type="danger" size="mini" @@click="fieldDeleteHandel($event,item.id)">@CR["Common.Delete"]</el-button>
                                    </div>
                                </div>
                            </el-option>
                        </el-select>
                    </div>

                    <div class="w-100">
                        <div class="d-flex align-center justify-content-between" style="gap: 5px;margin-bottom: 5px">
                            <div class="d-flex align-center" style="gap: 5px;">
                                <img src="~/image/PromptRange/prompt_selectPrompt.svg" alt="" class="imgIcon" />
                                <div class="titleContent">@AR["Auto.UI.8f115163a424"]</div>
                            </div>
                            <div class="d-flex align-center" style="gap: 5px;">
                                <el-button type="primary" size="mini" icon="el-icon-magic-stick" @@click="openOptimizeDialog" 
                                    style="background: linear-gradient(135deg, #ff9a9e 0%, #fecfef 100%); border: none; font-weight: bold; color: #333;">
                                    @AR["Auto.UI.aa84ec947f0a"]
                                </el-button>
                                <el-button type="primary" size="mini" icon="el-icon-s-data" @@click="openMapDialog" 
                                    style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border: none; font-weight: bold;">
                                    @AR["Auto.UI.e40c634367e3"]
                                </el-button>
                                <i class="el-icon-document-copy" style="font-size: 1.3rem;cursor: pointer" @@click="copyInfo"></i>
                            </div>
                        </div>
                        <el-select v-model="promptid" :disabled="!promptField" :popper-append-to-body="true" :placeholder="@AR["Auto.UI.3c321cef9992"]" class="selectRow" @@change="promptChangeHandel($event,'promptid')">
                            <el-option v-for="item in promptOpt"
                                       v-key="item.id"
                                       :label="item.label"
                                       :value="item.value"
                                       :disabled="item.disabled">
                                <div class="d-flex justify-content-between align-center" style="gap:20px">
                                    <span>{{ item.label }}</span>
                                    <div style="display: flex; gap: 5px;">
                                        <el-button type="success" size="mini" icon="el-icon-s-data" @@click="openCompareDialog($event, item)">@AR["Auto.UI.f5deaa1716cb"]</el-button>
                                        <el-button type="primary" size="mini" @@click="promptNameField($event,item)">{{item.nickName ? 'Rename target lane' : 'Set target lane name'}}</el-button>
                                        <el-button type="primary" size="mini" @@click="promptNameRest($event,item.id)">@AR["Auto.UI.5158eebd4f1f"]</el-button>
                                        <el-button type="danger" size="mini" @@click="promptDeleteHandel($event,item.id)">@CR["Common.Delete"]</el-button>
                                    </div>
                                </div>
                            </el-option>
                        </el-select>
                    </div>
                </div>
            </div>
            @* Select Model *@
            <div class="configurineAreaItem modelBox" style="width: 100%;">
                <div class="titleRow" style="padding: 5px">
                    <div class="titleRow_leftBox">
                        <img src="~/image/PromptRange/prompt_selectModel.svg" alt="" class="imgIcon" />
                        <div class="titleContent">@AR["Auto.UI.f2d3731b92d0"]</div>
                    </div>
                    <div class="d-flex" style="gap:5px">
                        <el-button size="mini" @@click="refreshModelOpt" :loading="waitRefreshModel">@AR["Auto.UI.694fc5efa9e1"]</el-button>
                        <el-button type="primary" size="mini" @@click="toAIKernel">@AR["Auto.UI.8343cb006c1a"]</el-button>
                    </div>
                </div>
                <div>
                    <el-select v-model="modelid" placeholder="@AR["Auto.UI.0e34a1fe3234"]" :disabled="dodgersLoading" class="selectRow model-select" @@change="promptChangeHandel($event,'modelid',modelid)">
                        <el-option v-for="item in modelOpt"
                                   v-key="item.id"
                                   :label="item.displayName || item.alias"
                                   :value="item.value"
                                   :disabled="item.disabled">
                            <div class="model-option-content">
                                <div class="model-name-row">
                                    <span class="model-name">{{ item.alias || 'Unnamed model' }}</span>
                                    <span class="model-version" v-if="item.apiVersion">v{{ item.apiVersion }}</span>
                                </div>
                                <div class="model-deployment" v-if="item.deploymentName">（{{ item.deploymentName }}）</div>
                            </div>
                        </el-option>
                    </el-select>
                </div>
            </div>
            @* Input *@
            <div class="boxCard inputPromptArea" style="padding: 0">
                @* Please create or select a range mask *@
                <div class="prompt-mask" v-if="promptFieldOpt.length===0||!promptField" style="z-index: 1350;">
                    <div class="text-center">
                        <i class="el-icon-lock" style="font-size:2.5rem"></i>
                        <br>@AR["Auto.UI.dee46b9ddb11"]
                    </div>
                </div>
                @* Burst mode mask *@
                <div class="prompt-mask" v-if="dodgersLoading">
                    <div class="text-center">
                        <i class="el-icon-lock" style="font-size:2.5rem"></i>
                        <br>@AR["Auto.UI.434eb2c61600"]
                        <br>@AR["Auto.UI.e0f8cac65800"]
                    </div>
                </div>
                @* Model parameter settings *@
                <div class="configurineAreaItem paramBox" style="padding: 15px">
                    <div class="titleRow">
                        <div class="titleRow_leftBox">
                            <i class="requirIcon">*</i>
                            <div class="titleContent">@AR["Auto.UI.01cc6b26131c"]</div>
                        </div>
                       <div class="titleRow_rightBox">
                            @* parameterViewShow=!parameterViewShow *@
                            <el-button size="mini" @@click="resetConfigurineParam(true)">@CR["Common.Reset"]</el-button>
                            @* <i class="el-icon-caret-top icon" :class="{'rotate':parameterViewShow}" @@click="parameterViewToggle"></i>*@
                        </div>
                    </div>
                    <div class="paramBox_contentBox" :class="{'paramBox_contentBoxCollapse':parameterViewShow}">
                        <div v-for="item in parameterViewList" v-key="item.formField" class="paramBox_contentBox_item">
                            <div class="lableRow">
                                <div class="lableBtn">
                                    <span>{{ item.label }}</span>
                                    <el-tooltip class="item" effect="dark" :content="item.tips" placement="top">
                                        <i class="el-icon-warning-outline"></i>
                                    </el-tooltip>
                                </div>
                            </div>
                            @* v-bind: *@
                            <el-input v-model="item.value" placeholder="" class="inputBox" v-bind:style="{'flex':item.isSlider?'':'1'}" @@input="parameterInputHandle($event,item)" @@change="promptChangeHandel($event,item.formField)"></el-input>
                            <div v-if="item.isSlider" class="sliderBox">
                                <span>{{item.sliderMin}}</span>
                                <el-slider v-model="item.value" :min="item.sliderMin" :max="item.sliderMax" :step="item.sliderStep" class="slider" @@change="promptChangeHandel($event,item.formField)"></el-slider>
                                <span>{{item.sliderMax}}</span>
                            </div>
                        </div>
                    </div>
                </div>
                @* Set AI scoring criteria :disabled="!promptid" aiScoreFormOpenDialog aiScoreFormVisible = true *@
                <div style="padding-left: 15px; margin-top:25px;">
                    <el-button type="primary" :disabled=!isAIGrade size="mini" @@click="aiScoreFormOpenDialog">@AR["Auto.UI.6c0c254bfcec"]</el-button>
                    <el-switch active-color="#13ce66" inactive-color="#ff4949" v-model="isAIGrade" active-text="On" inactive-text="Off"></el-switch>
                </div>
            </div>
        </div>
        <div class="trapezoid" @@click="foldsidebar">
            <i class="el-icon-caret-right icon" style="position: absolute;top: 15px;" :class="{'sidebarview':foldsidebarShow}"></i>
        </div>

       
    </div>
    
    @* Draggable divider between left and center areas *@
    <div class="resize-handle resize-handle-left" 
         v-if="!promptLeftShow && !centerAreaMaximized && !rightAreaMaximized"
         @@mousedown="startResizeLeft"
         @@dblclick="resetAreaWidths"
         title="@AR["Auto.UI.b5c671b7e3ae"]"></div>
    
    @* Center Prompt Input *@
    <div class="promptPage_centerArea" 
         v-if="!box2Hidden" 
         :class="{'promptPage_centerAreaMaximized': centerAreaMaximized}"
         :style="!centerAreaMaximized && !rightAreaMaximized ? {width: centerAreaWidth + 'px'} : {}">
        <div class="boxCard entertarget" >
                @* Please create or select a range mask *@
                <div class="prompt-mask" v-if="promptFieldOpt.length===0||!promptField" style="z-index: 1350;">
                    <div class="text-center">
                        <i class="el-icon-lock" style="font-size:2.5rem"></i>
                        <br>@AR["Auto.UI.dee46b9ddb11"]
                    </div>
                </div>
                @* Burst mode mask *@
                <div class="prompt-mask" v-if="dodgersLoading">
                    <div class="text-center">
                        <i class="el-icon-lock" style="font-size:2.5rem"></i>
                        <br>@AR["Auto.UI.434eb2c61600"]
                        <br>@AR["Auto.UI.e0f8cac65800"]
                    </div>
                </div>
                @* Input Prompt *@
                <div class="promptContetnPmroparaBox" style="padding: 5px">
                    @* Input prompt content *@
                    <div class="configurineAreaItem leftItemBox">
                        <div class="titleRow">
                            <div class="titleRow_leftBox">
                                <img src="~/image/PromptRange/prompt_inputPrompt.svg" alt="" class="imgIcon" />
                                <div class="titleContent">@AR["Auto.UI.ee81d7ddd274"]</div>
                            </div>
                            <div class="titleRow_rightBox">
                                <el-button size="mini" @@click="resetInputPrompt">@CR["Common.Reset"]</el-button>
                                <el-button type="primary" size="mini" :icon="promptParamVisible?'el-icon-s-fold':'el-icon-s-unfold'" @@click="promptParamVisible = !promptParamVisible">@AR["Auto.UI.527466ff94bd"]</el-button>
                                <i class="el-icon-full-screen" style="font-size: 1.3rem;cursor: pointer;" @@click="Amplification('box2')"></i>
                            </div>
                        </div>
                        <div class="promptContentBox">
                        @* contenteditable editor supporting inline highlighting *@
                        <div class="promptInput prompt-rich-editor"
                             contenteditable="true"
                             ref="promptEditor"
                             @@input="handleEditorInput"
                             @@paste="handlePaste"
                             @@keydown="handleKeyDown"
                             @@blur="applyHighlight"
                             @@compositionstart="isComposing = true"
                             @@compositionend="isComposing = false"
                             :data-placeholder="@AR["Auto.UI.5618aab0e92b"]">
                        </div>
                            
                            @* Variable hint card *@
                            <div class="prompt-variables-hint" v-if="detectedVariables.length > 0">
                                <div class="hint-title">
                                    <i class="el-icon-info"></i>
                                    Detected {{ detectedVariables.length }} variable(s)
                                </div>
                                <div class="variables-list">
                                    <el-tag v-for="varItem in detectedVariables" 
                                            :key="varItem.name"
                                            :type="varItem.isDefined ? 'success' : 'danger'"
                                            size="small"
                                            class="variable-tag">
                                        {{ varItem.fullMatch }}
                                        <i v-if="varItem.isDefined" class="el-icon-check" title="@AR["Auto.UI.7b757faf9f11"]"></i>
                                        <i v-else class="el-icon-warning" title="@AR["Auto.UI.cebc6bbbeb66"]"></i>
                                    </el-tag>
                                </div>
                            </div>
                            <div class="remarkRow">
                                <el-input v-model="remarks" type="textarea"
                                          :rows="4"
                                          resize="none"
                                          maxlength="200"
                                          show-word-limit
                                          placeholder="@AR["Auto.UI.3cac6342966f"]" class="remarkInputBox" @@change="promptChangeHandel($event,'remarks')" @@blur="promptRemarkSave">
                                </el-input>
                                @* style="z-index: 1250;" *@
                                <div class="operationBox">
                                    @* Select burst count *@
                                    <el-dropdown trigger="click" @@command="changeNumsBtn" type="primary" size="small">
                                        <div class="numsOfResultsBox">
                                            @AR["Auto.UI.26f647fad995"]<span class="numVal">{{numsOfResults}}</span>
                                            <i class="el-icon-arrow-down"></i>
                                        </div>
                                        <el-dropdown-menu slot="dropdown">
                                            <el-dropdown-item v-for="btn of numsOfResultsOpt" :key="btn" :command="btn">{{btn}}</el-dropdown-item>
                                        </el-dropdown-menu>
                                    </el-dropdown>
                                    @* Shooting button  v-loading="targetShootLoading" *@
                                    <div class="targetShootBtnRow">
                                        <el-dropdown trigger="click" @@command="changeBtn" split-button type="primary" @@click="clickSendBtn" size="small">
                                            {{sendBtnText}}
                                            <el-dropdown-menu slot="dropdown">
                                                <el-dropdown-item v-for="btn of sendBtns" :key="btn.text" :disabled="btn.text==='连发'&&(!promptid||outputList.length===0||pageChange)" :command="btn.text">{{btn.text}}</el-dropdown-item>
                                            </el-dropdown-menu>
                                        </el-dropdown>
                                        <el-tooltip class="item" effect="dark" placement="top">
                                            <div slot="content" class="">@AR["Auto.UI.ed4ffbe659c5"]<br />@AR["Auto.UI.d8163777fc1c"]<br />@AR["Auto.UI.f059404dd886"]</div>
                                            <i class="el-icon-warning-outline" :style="sendBtnText==='连发'?'filter:invert(1)':''"></i>
                                        </el-tooltip>
                                    </div>
                                </div>
                            </div>
                        </div>
                        @* Prompt request parameters - moved inside leftItemBox as the lower section *@
                        <div class="promptParamSection" :class="{'paramSectionHide': !promptParamVisible}">
                        <div class="titleRow" style="height:28px;">
                            <div class="titleRow_leftBox">
                                <div class="titleContent">@AR["Auto.UI.826feca4911a"]</div>
                            </div>
                        </div>
                        <div class="promptPmroparaBox">
                            <el-form ref="promptParamForm" :model="promptParamForm" :rules="rules" label-width="70px" label-position="left">
                                <div class="formItem">
                                    <el-form-item label="@AR["Auto.UI.4c9bb42608b1"]" prop="prefix">
                                        <el-input size="mini" v-model="promptParamForm.prefix" autocomplete="off" placeholder="@AR["Auto.UI.f2170b1fad81"]"></el-input>
                                    </el-form-item>
                                    <el-form-item label="@AR["Auto.UI.242d641eab57"]" prop="suffix">
                                        <el-input size="mini" v-model="promptParamForm.suffix" autocomplete="off" placeholder="@AR["Auto.UI.7e464d0d84ea"]"></el-input>
                                    </el-form-item>
                                </div>
                                @* Variable name and value *@
                                <el-table :data="promptParamForm.variableList" border
                                          max-height="150"
                                          style="width: 100%">
                                    <el-table-column label="@AR["Auto.UI.a25657422b40"]">
                                        <template slot-scope="scope">
                                            @*<el-input size="mini" v-model="scope.row.name" autocomplete="off" placeholder="@AR["Auto.UI.86bf87636a0f"]"></el-input>*@
                                            <el-input size="mini" type="textarea"
                                                      autosize
                                                      autocomplete="off"
                                                      placeholder="@AR["Auto.UI.86bf87636a0f"]"
                                                      v-model="scope.row.name">
                                            </el-input>
                                            @* <el-form-item :prop="'variableList.' + scope.$index + '.name'" :rules="rules.variableName" label-width="0px">
                                            <el-input size="mini" v-model="scope.row.name" autocomplete="off" placeholder="@AR["Auto.UI.86bf87636a0f"]"></el-input>
                                            </el-form-item> *@
                                        </template>
                                    </el-table-column>
                                    <el-table-column label="@AR["Auto.UI.9a2ee7044ff0"]">
                                        <template slot-scope="scope">
                                            @*<el-input size="mini" v-model="scope.row.value" autocomplete="off" placeholder="@AR["Auto.UI.85451d2eb593"]"></el-input>*@
                                            <el-input size="mini" type="textarea"
                                                      autosize
                                                      autocomplete="off"
                                                      placeholder="@AR["Auto.UI.85451d2eb593"]"
                                                      v-model="scope.row.value">
                                            </el-input>
                                            @* <el-form-item :prop="'variableList.' + scope.$index + '.value'" :rules="rules.variableValue" label-width="0px">
                                            <el-input size="mini" v-model="scope.row.value" autocomplete="off" placeholder="@AR["Auto.UI.85451d2eb593"]"></el-input>
                                            </el-form-item> *@
                                        </template>
                                    </el-table-column>
                                    <el-table-column label="@CR["Common.Action"]" width="50">
                                        <template slot-scope="scope">
                                            <i class="el-icon-delete deleteIcon" @@click="deleteVariableBtn(scope.$index)"></i>
                                        </template>

                                    </el-table-column>
                                </el-table>
                                @* <div v-for="(item,index) in promptParamForm.variableList" v-key="index" class="formItem">
                                <el-form-item label="" :prop="'variableList.' + index + '.name'" :rules="rules.variableName" label-width="0px">
                                <el-input v-model="item.name" autocomplete="off" placeholder="@AR["Auto.UI.86bf87636a0f"]"></el-input>
                                </el-form-item>
                                <el-form-item label="" :prop="'variableList.' + index + '.value'" :rules="rules.variableValue" label-width="0px">
                                <el-input v-model="item.value" autocomplete="off" placeholder="@AR["Auto.UI.85451d2eb593"]"></el-input>
                                </el-form-item>
                                <i class="el-icon-delete deleteIcon" @@click="deleteVariableBtn(index)"></i>
                                </div> *@
                                <div class="addVariableRow">
                                    <el-button type="primary" size="mini" icon="el-icon-plus" @@click="addVariableBtn">@AR["Auto.UI.eb3818a316b8"]</el-button>
                                </div>
                            </el-form>
                            <div class="footerBtnRow">
                                @* <el-button size="mini" @@click="promptParamFormClose">@CR["Common.Cancel"]</el-button> *@
                                @* <el-button type="primary" size="mini" v-loading="promptParamFormLoading" @@click="promptParamFormSubmit">@CR["Common.Confirm"]</el-button> *@
                            </div>
                        </div>
                        </div>
                    </div>
                </div>


            </div>
    </div>
    
    @* Draggable divider between center and right areas *@
    <div class="resize-handle resize-handle-right" 
         v-if="!box2Hidden && !centerAreaMaximized && !rightAreaMaximized"
         @@mousedown="startResizeRight"
         @@dblclick="resetAreaWidths"
         title="@AR["Auto.UI.b5c671b7e3ae"]"></div>
    
    @* Right side scoring/analysis *@
    <div class="promptPage_rightArea" 
         :class="{'promptPage_rightAreaMaximized': rightAreaMaximized, 'promptPage_rightAreaHidden': box1Hidden && box3Hidden}">
        @* Output *@
        <div class="boxCard outputArea" 
             :style="{'z-index':isPageLoading && dodgersLoading ? 1000000 : 999}" 
             v-if="!box1Hidden"
             @@mousemove="handleOutputAreaMouseMove"
             @@mouseleave="handleOutputAreaMouseLeave">
            <div class="promptVersion">
                <div class="promptVersion-content">
                    <div class="promptVersion-row">
                        <span>@AR["Auto.UI.6eb70a4114e7"] <strong>{{promptDetail.fullVersion}}</strong></span>
                        <i class="el-icon-document-copy" style="font-size: 1.0rem;cursor: pointer;margin-left: 8px;" @@click="copyInfo"></i>
                    </div>
                    <div class="promptVersion-row promptVersion-info">
                        <span style="margin-right:5px;">@AR["Auto.UI.24e567ff9878"]</span>
                        <span style="margin-right:15px;">{{promptDetail.promptFieldStr||'--'}}</span>
                        <span style="margin-right:5px;">@AR["Auto.UI.98e1aba1b47e"]</span>
                        <span style="margin-right:15px;">{{promptDetail.promptStr||'--'}}</span>
                        <span style="margin-right:5px;">@AR["Auto.UI.6f7e2c12f4cc"]</span>
                        <span>{{promptDetail.tacticsStr||'--'}}</span>
                    </div>
                </div>
                <span><i class="el-icon-full-screen" style="font-size: 1.3rem;cursor: pointer;" @@click="Amplification('box1')"></i></span>
            </div>
          
            <div class="titleRow">
                <div class="titleRow_leftBox">
                    <img src="~/image/PromptRange/prompt_output.svg" alt="" class="imgIcon" />
                    <div class="titleContent">@AR["Auto.UI.8ba7c3a7bef9"]</div>
                </div>
                <div class="titleRow_scoreBox">
                    <span>@AR["Auto.UI.55d56c3f050b"]</span>
                    <span>{{outputAverageDeci>-1?outputAverageDeci.toFixed(1):'--'}}</span>
                </div>
                <div class="titleRow_scoreBox">
                    <span>@AR["Auto.UI.cf37da5e58f0"]</span>
                    <span>{{outputMaxDeci>-1?outputMaxDeci.toFixed(1):'--'}}</span>
                </div>
            </div>
            <div class="outputArea_contentBox" id="resultBox" @@scroll="handleResultScroll">
                <div v-for="(item,index) in outputList" v-key="item.id" class="contentBoxItem" v-bind:class="{'contentBoxActiveItem':outputActive === index}" @@click="app.outputSelectSwitch(index)" :data-result-index="index">
                    <div class="promptResult_Item_Title">
                        <div class="promptReultTimeArea">
                            <span>{{item.addTime}} [Elapsed (ms):{{item.costTime}}]</span>
                        </div>
                        <div class="copyButtonArea">
                            <a href="javascript:void(0);" @@click="copyPromptResult(item,false)" title="@AR["Auto.UI.c6255f9bac17"]"><i class="fa fa-copy"></i> HTML</a>
