                    </el-checkbox>
                    <el-checkbox v-model="autoAIGradeAfterShoot" :disabled="!autoShootAfterOptimize" style="margin-left: 20px;">
                        <span style="font-weight: 500;">@AR["Auto.UI.89ffdd535631"]</span>
                        <el-tooltip content="打靶完成后自动调用 AI 评分功能，快速获得质量反馈" placement="top">
                            <i class="el-icon-question" style="color: #909399; margin-left: 5px;"></i>
                        </el-tooltip>
                    </el-checkbox>
                </el-form-item>
            </el-form>
        </div>
        <span slot="footer" class="dialog-footer">
            <el-button @@click="optimizeDialogVisible = false">@CR["Common.Cancel"]</el-button>
            <el-button type="primary" @@click="executeOptimize" :loading="optimizing" :disabled="optimizing">@AR["Auto.UI.855bc1014072"]</el-button>
        </span>
    </el-dialog>

    @* PromptCatalyzer 初始化对话框 *@
    <el-dialog title="@AR["Auto.UI.6078586e5517"]" 
               :visible.sync="promptCatalyzerInitVisible" 
               width="55%" 
               :close-on-click-modal="false"
               center>
        <div class="init-dialog-content">
            <el-alert title="@AR["Auto.UI.f8d9dcffa375"]" 
                      type="info" 
                      show-icon 
                      :closable="false" 
                      style="margin-bottom: 20px;">
                <template slot>
                    <p style="margin: 5px 0;">@AR["Auto.UI.2ea3ccc65748"] <strong>PromptCatalyzer Agent</strong>。</p>
                    <p style="margin: 5px 0;">@AR["Auto.UI.9e44c4d8008c"]</p>
                </template>
            </el-alert>
            
            <el-form label-position="top">
                <el-form-item label="@AR["Auto.UI.dda6d6675945"]" required>
                    <el-select v-model="selectedModelIdForInit" 
                               placeholder="@AR["Auto.UI.0655a7c2480f"]" 
                               style="width: 100%;"
                               :loading="loadingModels"
                               filterable>
                        <el-option v-for="model in availableModelsForInit"
                                   :key="model.id"
                                   :label="model.alias"
                                   :value="model.id">
                            <div style="display: flex; justify-content: space-between; align-items: center; padding: 5px 0;">
                                <span style="font-weight: 600; color: #303133;">{{ model.alias }}</span>
                                <el-tag size="mini" type="info">{{ model.aiPlatform }}</el-tag>
                            </div>
                            <div style="font-size: 12px; color: #909399; margin-top: 4px; padding-left: 5px;">
                                <span>{{ model.deploymentName }}</span>
                                <span v-if="model.note" style="margin-left: 8px; color: #67C23A;">| {{ model.note }}</span>
                            </div>
                        </el-option>
                    </el-select>
                    <div style="margin-top: 10px; padding: 8px 12px; background-color: #f4f4f5; border-radius: 4px; font-size: 12px; color: #606266;">
                        <i class="el-icon-info" style="color: #409EFF; margin-right: 4px;"></i>
                        <strong>@AR["Auto.UI.390a4d9af6ec"]</strong>@AR["Auto.UI.4578b1eac74a"]
                    </div>
                </el-form-item>
                
                <el-form-item label="@AR["Auto.UI.2fe3a7333f9f"]" v-if="selectedModelIdForInit">
                    <el-descriptions :column="2" border size="small">
                        <el-descriptions-item label-class-name="desc-label">
                            <template slot="label">
                                <el-tooltip content="控制输出的随机性：0.0-1.0，越低越精确，越高越创意" placement="top">
                                    <span>Temperature <i class="el-icon-question"></i></span>
                                </el-tooltip>
                            </template>
                            <el-tag size="mini" type="success">0.7</el-tag>
                            <span style="margin-left: 8px; color: #909399; font-size: 12px;">@AR["Auto.UI.e2d5bda3c22a"]</span>
                        </el-descriptions-item>
                        <el-descriptions-item label-class-name="desc-label">
                            <template slot="label">
                                <el-tooltip content="核采样参数：0.0-1.0，控制词汇选择范围" placement="top">
                                    <span>TopP <i class="el-icon-question"></i></span>
                                </el-tooltip>
                            </template>
                            <el-tag size="mini" type="success">0.9</el-tag>
                            <span style="margin-left: 8px; color: #909399; font-size: 12px;">@AR["Auto.UI.142d5f934bee"]</span>
                        </el-descriptions-item>
                        <el-descriptions-item label-class-name="desc-label">
                            <template slot="label">
                                <el-tooltip content="生成的最大 token 数量，影响输出长度" placement="top">
                                    <span>MaxTokens <i class="el-icon-question"></i></span>
                                </el-tooltip>
                            </template>
                            <el-tag size="mini" type="success">4000</el-tag>
                            <span style="margin-left: 8px; color: #909399; font-size: 12px;">@AR["Auto.UI.c583d00a0432"]</span>
                        </el-descriptions-item>
                        <el-descriptions-item label-class-name="desc-label">
                            <template slot="label">
                                <el-tooltip content="频率惩罚：-2.0 到 2.0，减少重复词汇" placement="top">
                                    <span>FrequencyPenalty <i class="el-icon-question"></i></span>
                                </el-tooltip>
                            </template>
                            <el-tag size="mini" type="success">0</el-tag>
                            <span style="margin-left: 8px; color: #909399; font-size: 12px;">@AR["Auto.UI.b7e6ea5690b2"]</span>
                        </el-descriptions-item>
                    </el-descriptions>
                    <div style="margin-top: 8px; font-size: 12px; color: #909399; text-align: center;">
                        @AR["Auto.UI.31a854cc42cc"]
                    </div>
                </el-form-item>
            </el-form>
        </div>
        <span slot="footer" class="dialog-footer">
            <el-button @@click="promptCatalyzerInitVisible = false" :disabled="initializing">@CR["Common.Cancel"]</el-button>
            <el-button type="primary" 
                       @@click="executeInitialization" 
                       :loading="initializing"
                       :disabled="!selectedModelIdForInit">
                <i class="el-icon-magic-stick" v-if="!initializing"></i>
                {{ initializing ? '初始化中...' : '开始初始化' }}
            </el-button>
        </span>
    </el-dialog>
    
</div>


<div v-if="isPageLoading" class="promptLoaderBox">
    <div class="loading">
        <div></div>
        <div></div>
        <div></div>
        <div></div>
    </div>
</div>

