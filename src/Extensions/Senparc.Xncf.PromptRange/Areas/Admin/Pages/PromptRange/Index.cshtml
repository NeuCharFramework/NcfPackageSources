@page
@model Senparc.Xncf.PromptRange.Areas.PromptRange.Pages.Index
@inject Microsoft.Extensions.Localization.IStringLocalizerFactory LocalizerFactory
@{    var AR = LocalizerFactory.Create("Senparc.Areas.Admin.Resources.AdminResource", "Senparc.Areas.Admin");
    var CR = LocalizerFactory.Create("Senparc.Ncf.XncfBase.Resources.CommonResource", "Senparc.Ncf.XncfBase");

    ViewData["Title"] = AR["Auto.UI.2ff254e2be7e"];
    Layout = "_Layout_Vue";
}
@section Style{
    <link href="https://unpkg.com/element-ui/lib/theme-chalk/index.css" rel="stylesheet">
    <link href="~/css/PromptRange/index.css" rel="stylesheet" />
}
@section breadcrumbs{
    <el-breadcrumb-item>@CR["Common.ExtensionModules"]</el-breadcrumb-item>
    <el-breadcrumb-item>@AR["PromptRange.ModuleName"]</el-breadcrumb-item>
    <el-breadcrumb-item>@CR["Common.Home"]</el-breadcrumb-item>
}

<div class="indexPage">
    <div class="headRow">
        <div class="leftBox">
            <div class="title">
                <div>PromptRange</div>
                <div>@AR["PromptRange.ModuleName"]</div>
            </div>
            <div class="btn">
                @AR["Auto.UI.1cbddef0b578"]
            </div>
        </div>
        <img src="~/image/PromptRange/index_headBg.png" class="headBg" />
        <img src="~/image/PromptRange/index_headRight1.png" class="headRightIcon1" />
        <img src="~/image/PromptRange/index_headRight2.png" class="headRightIcon2" />
        <img src="~/image/PromptRange/index_headRight3.png" class="headRightIcon3" />
    </div>
    <div class="mainBox">
        <div class="leftBox cardBox"> 
            <div id="rank">
                <h1>@AR["Auto.UI.e41eb186a9d6"]</h1>
                <div class="ranking-container">
                    <div class="ranking">
                        <h2>@AR["Auto.UI.54124e5981b3"]</h2>
                        <ol id="ol">
                            <li id="li" v-for="(prompt, index) in topPrompts" :key="index">
                                <span class="rank">{{ index + 1 }}</span>
                                <span class="content">{{ prompt.text }}</span>
                                <span class="usage">使用次数: {{ prompt.usageCount }}</span>
                            </li>
                        </ol>
                    </div>
                    <div class="ranking">
                        <h2>@AR["Auto.UI.e7ce83e39f4f"]</h2>
                        <ol id="ol">
                            <li id="li" v-for="(model, index) in topModels" :key="index">
                                <span class="rank">{{ index + 1 }}</span>
                                <span class="content">{{ model.name }}</span>
                                <span class="usage">调用次数: {{ model.usageCount }}</span>
                            </li>
                        </ol>
                    </div>
                </div>
            </div>
            <div class="hotMainBox"></div>
        </div>
        <div class="rightBox">
            <div class="cardBox">
                @* <div id="chart">
                    <h1>@AR["Auto.UI.3dfb165b3cdb"]</h1>
                    <el-date-picker v-model="dateRange"
                                    type="daterange"
                                    range-separator="至"
                                    start-placeholder="@AR["Auto.UI.b44c0f337d2f"]"
                                    end-placeholder="@AR["Auto.UI.1d468be946f7"]"
                                    v-on:change="updateChart"
                                    style="margin-bottom: 20px;" >
                    </el-date-picker>
                    <div ref="chart" id="chart2" ></div>
                </div> *@
                <div class="usetimes">
                    <h1 class="title">@AR["Auto.UI.3dfb165b3cdb"]</h1>
                    <div id="main"></div>
                    <div class="hotMainBox"></div>
                </div>
            </div>
        </div>
    </div>
</div>

@section scripts{
    <script src="~/js/PromptRange/echarts/echarts.min.js"></script>
    <script src="~/js/PromptRange/echarts/echarts-gl.min.js"></script>
    <script src="~/js/PromptRange/index.js"></script>
    <script src="https://unpkg.com/element-ui/lib/index.js"></script>
    <script src="https://unpkg.com/vue@2"></script>
}
