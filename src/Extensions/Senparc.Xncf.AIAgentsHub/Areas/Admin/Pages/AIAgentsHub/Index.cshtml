@page
@model Senparc.Xncf.AIAgentsHub.Areas.AIAgentsHub.Pages.Index
@inject Microsoft.Extensions.Localization.IStringLocalizerFactory LocalizerFactory
@{    var AR = LocalizerFactory.Create("Senparc.Areas.Admin.Resources.AdminResource", "Senparc.Areas.Admin");
    var CR = LocalizerFactory.Create("Senparc.Ncf.XncfBase.Resources.CommonResource", "Senparc.Ncf.XncfBase");

    ViewData["Title"] = AR["Auto.UI.aded59eee9b7"];
    Layout = "_Layout_Vue";
}

@section breadcrumbs{
    <el-breadcrumb-item>@CR["Common.ExtensionModules"]</el-breadcrumb-item>
    <el-breadcrumb-item>AI Agent Hub</el-breadcrumb-item>
    <el-breadcrumb-item>@CR["Common.Home"]</el-breadcrumb-item>
}

<div>
    <el-container>
        <el-header class="module-header">
            <span class="start-title"> <i class="fa fa-dot-circle-o"></i>&nbsp;<span class="module-header-v">@CR["Common.Home"]</span></span>
        </el-header>

        <!-- 此处也可以加 SideMenu -->
        @*<el-aside width="200px">
            <el-menu background-color="#304156" default-active="1"
                        text-color="#bfcbd9" active-text-color="#409eff">
                @(await Html.PartialAsync("_SideMenu"))
            </el-menu>
        </el-aside>*@
        <el-main>
            <h3>@Model.XncfRegister.MenuName / @Model.XncfRegister.Name</h3>
            <h4>@Model.XncfRegister.Description</h4>
            <br />
            <i>@CR["Common.AutoGeneratedModule"]</i>
        </el-main>
    </el-container>
</div>


@section scripts{
    <script>
        new Vue({
            el: "#app"
        });
    </script>
}
